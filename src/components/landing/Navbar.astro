---
const isHome = Astro.url.pathname === "/";
const link = (id) => isHome ? `#${id}` : `/#${id}`;
---

<nav id="navbar"
     class="fixed top-0 left-0 right-0 z-[100] flex items-center justify-between px-10 py-6 transition-[background-color,backdrop-filter,padding,border-color] duration-[350ms] ease-hostal border-b border-transparent"
     role="navigation" aria-label="Menú principal">

  <a href={isHome ? "#" : "/"} class="font-serif text-2xl font-light text-snow no-underline tracking-[0.02em] transition-opacity duration-200 hover:opacity-80" aria-label="Hostal El Monchito — Inicio">
    El <em class="text-fern italic">Monchito</em>
  </a>

  <ul class="hidden lg:flex gap-10 list-none">
    <li><a href={link("about")}        class="nav-link-hover text-white/65 no-underline text-[0.75rem] tracking-[0.12em] uppercase transition-colors duration-200 hover:text-snow">Nosotros</a></li>
    <li><a href={link("services")}     class="nav-link-hover text-white/65 no-underline text-[0.75rem] tracking-[0.12em] uppercase transition-colors duration-200 hover:text-snow">Servicios</a></li>
    <li><a href={link("gallery")}      class="nav-link-hover text-white/65 no-underline text-[0.75rem] tracking-[0.12em] uppercase transition-colors duration-200 hover:text-snow">Entorno</a></li>
    <li><a href={link("testimonials")} class="nav-link-hover text-white/65 no-underline text-[0.75rem] tracking-[0.12em] uppercase transition-colors duration-200 hover:text-snow">Reseñas</a></li>
    <li><a href={link("faq")}          class="nav-link-hover text-white/65 no-underline text-[0.75rem] tracking-[0.12em] uppercase transition-colors duration-200 hover:text-snow">Preguntas</a></li>
    <li><a href={link("blog")}         class="nav-link-hover text-white/65 no-underline text-[0.75rem] tracking-[0.12em] uppercase transition-colors duration-200 hover:text-snow">Blog</a></li>
  </ul>

  <div class="flex items-center gap-2">

    <!-- Botón: Iniciar Sesión -->
    <a href="/login"
       class="hidden lg:inline-flex items-center gap-1.5
              text-white/60 hover:text-snow
              border border-white/20 hover:border-white/50
              bg-transparent hover:bg-white/[0.06]
              px-4 py-2 rounded-[10px]
              text-[0.72rem] font-medium tracking-[0.08em] uppercase
              backdrop-blur-sm
              transition-all duration-[250ms] ease-hostal
              no-underline">
      <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
        <circle cx="12" cy="7" r="4"/>
      </svg>
      Iniciar Sesión
    </a>

    <!-- Botón: Reservar -->
    <a href={link("footer")}
       class="hidden lg:inline-flex items-center gap-1.5
              text-snow
              bg-sage hover:bg-fern2
              px-5 py-[0.55rem] rounded-[10px]
              text-[0.72rem] font-semibold tracking-[0.1em] uppercase
              shadow-hostal-fern hover:shadow-fern-hover
              hover:-translate-y-px
              transition-all duration-[250ms] ease-hostal
              no-underline">
      Reservar
    </a>

    <!-- Hamburger -->
    <button id="hamburger-btn"
            class="flex lg:hidden flex-col gap-[5px] bg-transparent border border-white/20 rounded-[10px] cursor-pointer p-[0.55rem_0.65rem] transition-colors duration-200 hover:border-white/50"
            aria-label="Abrir menú móvil" aria-expanded="false">
      <span class="block w-5 h-[1.5px] bg-snow transition-all duration-300"></span>
      <span class="block w-5 h-[1.5px] bg-snow transition-all duration-300"></span>
      <span class="block w-5 h-[1.5px] bg-snow transition-all duration-300"></span>
    </button>
  </div>
</nav>

<!-- ===== MOBILE MENU ===== -->
<div id="mobile-menu"
     class="hidden fixed inset-0 z-[200] bg-[rgba(10,11,10,0.97)] backdrop-blur-2xl flex-col items-center justify-center gap-2"
     role="dialog" aria-modal="true" aria-label="Menú de navegación">

  <button id="mobile-close-btn"
          class="absolute top-6 right-6 bg-white/[0.08] border border-white/[0.15] rounded-full w-10 h-10 flex items-center justify-center text-snow text-lg cursor-pointer transition-colors duration-200 hover:bg-white/[0.15]"
          aria-label="Cerrar menú">✕</button>

  <nav class="flex flex-col items-center" aria-label="Menú móvil">
    <a href={link("about")}        class="font-serif text-white/70 no-underline text-[2.6rem] font-light block text-center py-[0.4rem] px-8 transition-all duration-300 hover:text-snow hover:translate-x-2">Nosotros</a>
    <div class="w-px h-10 bg-gradient-to-b from-transparent via-white/20 to-transparent my-2"></div>
    <a href={link("services")}     class="font-serif text-white/70 no-underline text-[2.6rem] font-light block text-center py-[0.4rem] px-8 transition-all duration-300 hover:text-snow hover:translate-x-2">Servicios</a>
    <div class="w-px h-10 bg-gradient-to-b from-transparent via-white/20 to-transparent my-2"></div>
    <a href={link("gallery")}      class="font-serif text-white/70 no-underline text-[2.6rem] font-light block text-center py-[0.4rem] px-8 transition-all duration-300 hover:text-snow hover:translate-x-2">Entorno</a>
    <div class="w-px h-10 bg-gradient-to-b from-transparent via-white/20 to-transparent my-2"></div>
    <a href={link("testimonials")} class="font-serif text-white/70 no-underline text-[2.6rem] font-light block text-center py-[0.4rem] px-8 transition-all duration-300 hover:text-snow hover:translate-x-2">Reseñas</a>
    <div class="w-px h-10 bg-gradient-to-b from-transparent via-white/20 to-transparent my-2"></div>
    <a href={link("faq")}          class="font-serif text-white/70 no-underline text-[2.6rem] font-light block text-center py-[0.4rem] px-8 transition-all duration-300 hover:text-snow hover:translate-x-2">Preguntas</a>
    <div class="w-px h-10 bg-gradient-to-b from-transparent via-white/20 to-transparent my-2"></div>
    <a href={link("blog")}         class="font-serif text-white/70 no-underline text-[2.6rem] font-light block text-center py-[0.4rem] px-8 transition-all duration-300 hover:text-snow hover:translate-x-2">Blog</a>
    <div class="w-px h-10 bg-gradient-to-b from-transparent via-white/20 to-transparent my-2"></div>
    <a href={link("footer")}       class="font-serif text-white/70 no-underline text-[2.6rem] font-light block text-center py-[0.4rem] px-8 transition-all duration-300 hover:text-snow hover:translate-x-2">Reservar</a>
  </nav>

  <a href="/login"
     class="mt-6 inline-flex items-center gap-1.5
            text-white/65 hover:text-snow
            border border-white/20 hover:border-white/50
            bg-transparent hover:bg-white/[0.06]
            px-4 py-2 rounded-[10px]
            text-[0.72rem] tracking-[0.08em] uppercase
            backdrop-blur-sm
            transition-all duration-[250ms] ease-hostal
            no-underline">
    Iniciar Sesión
  </a>
</div>

<script>
  const navbar = document.getElementById('navbar');

  const onScroll = () => {
    const scrolled = window.scrollY;

    if (scrolled > 20) {
      const opacity = Math.min(0.85, 0.4 + scrolled / 600);
      navbar.style.backgroundColor = `rgba(8, 10, 8, ${opacity})`;
      navbar.style.backdropFilter = 'blur(18px)';
      navbar.style.webkitBackdropFilter = 'blur(18px)';
      navbar.style.borderBottomColor = 'rgba(255,255,255,0.07)';
      navbar.style.paddingTop    = scrolled > 80 ? '1rem' : '1.5rem';
      navbar.style.paddingBottom = scrolled > 80 ? '1rem' : '1.5rem';
    } else {
      navbar.style.backgroundColor = 'transparent';
      navbar.style.backdropFilter = 'none';
      navbar.style.webkitBackdropFilter = 'none';
      navbar.style.borderBottomColor = 'transparent';
      navbar.style.paddingTop    = '1.5rem';
      navbar.style.paddingBottom = '1.5rem';
    }
  };

  window.addEventListener('scroll', onScroll, { passive: true });

  // Hamburger
  const hamburger = document.getElementById('hamburger-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const closeBtn = document.getElementById('mobile-close-btn');

  const openMenu = () => {
    mobileMenu.classList.remove('hidden');
    mobileMenu.classList.add('flex');
    hamburger.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  };

  const closeMenu = () => {
    mobileMenu.classList.add('hidden');
    mobileMenu.classList.remove('flex');
    hamburger.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  };

  hamburger.addEventListener('click', openMenu);
  closeBtn.addEventListener('click', closeMenu);

  mobileMenu.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', closeMenu);
  });
</script>