---
import SeoSchema from './SeoSchema.astro';

// El dominio real es con www: el ápex redirige. Si el canonical apunta al
// ápex, Google recibe una URL que redirige y se confunde al indexar.
const SITIO = "https://www.hostalmonchito.cl";

const {
  title = "Hostal en Puerto Cisnes | Alojamiento y Pensión Completa – El Monchito",
  description = "Hostal en Puerto Cisnes con pensión completa, restaurante y convenios para empresas. Alojamiento para trabajadores y turistas en la Región de Aysén.",
  image = `${SITIO}/img/logo.png`,
  url = new URL(Astro.url.pathname, SITIO).href,
} = Astro.props;
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
<meta http-equiv="X-UA-Compatible" content="IE=edge" />

<title>{title}</title>
<meta name="description" content={description} />

<meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
<meta name="googlebot" content="index, follow, max-snippet:-1, max-image-preview:large" />

<link rel="canonical" href={url} />

<!-- GEO SEO -->
<meta name="geo.region" content="CL-AI" />
<meta name="geo.placename" content="Puerto Cisnes, Región de Aysén, Chile" />
<meta name="geo.position" content="-44.725;-72.755" />
<meta name="ICBM" content="-44.725, -72.755" />

<meta name="language" content="Spanish" />
<meta name="content-language" content="es-CL" />
<link rel="alternate" hreflang="es-CL" href={url} />

<!-- FAVICON -->
<link rel="icon" href="/img/logo.png" type="image/png" />
<link rel="apple-touch-icon" href="/img/logo.png" />

<!-- KEYWORDS -->
<meta name="keywords" content="hostal Puerto Cisnes, hospedaje Puerto Cisnes, alojamiento Puerto Cisnes, pensión completa Puerto Cisnes, alojamiento trabajadores Aysén, hostal Carretera Austral" />

<meta name="author" content="Hostal El Monchito" />
<meta name="publisher" content="Hostal El Monchito" />
<meta name="theme-color" content="#141412" />

<!-- OPEN GRAPH -->
<meta property="og:type" content="website" />
<meta property="og:site_name" content="Hostal El Monchito" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={image} />
<meta property="og:url" content={url} />
<meta property="og:locale" content="es_CL" />

<!-- TWITTER -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={image} />

<!-- PERFORMANCE -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link rel="preconnect" href="https://api.open-meteo.com" />

<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet" />

<!-- SCHEMA -->
<SeoSchema />

<!-- Tracking de visitas (excluye administradores) -->
<script>
  window.addEventListener("load", () => {
    const esAdmin = document.cookie.split(";").some((c) =>
      c.trim().toLowerCase().includes("authjs.session-token")
    );
    if (esAdmin) return;
    fetch("/api/track", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        pagina: window.location.pathname,
        referente: document.referrer || null,
      }),
    }).catch(() => {});
  });
</script>