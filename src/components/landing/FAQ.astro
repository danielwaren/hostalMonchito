<section
  id="faq"
  class="min-h-screen flex items-center py-[clamp(3.5rem,6vw,5.5rem)] px-[clamp(1.25rem,4vw,3rem)] bg-inkbase"
  aria-labelledby="faq-title"
>
  <div class="max-w-[820px] mx-auto w-full text-center">
    
    <!-- Header -->
    <p class="text-fern text-[0.62rem] font-medium tracking-[0.28em] uppercase mb-4 flex items-center justify-center gap-2 before:content-[''] before:block before:w-6 before:h-px before:bg-fern">
      Preguntas Frecuentes
    </p>

    <h2
      id="faq-title"
      class="font-serif text-[clamp(2.1rem,5vw,3.1rem)] font-light text-snow leading-[1.1] mb-3"
    >
      Todo sobre nuestros<br /><em class="italic text-fern">Servicios</em>
    </h2>

    <p class="text-white/[0.45] text-[0.92rem] mb-12">
      Hospedaje, alimentación y convenios en Puerto Cisnes
    </p>

    <!-- FAQ -->
    <div class="flex flex-col gap-5 text-left">
      
      <!-- ITEM -->
      <div class="faq-item bg-white/[0.025] border border-white/[0.06] rounded-[18px] overflow-hidden transition-all duration-300">
        <button class="faq-question w-full px-7 py-5 flex justify-between items-center text-snow text-[0.95rem] leading-[1.4]">
          ¿Ofrecen convenios de alojamiento y colaciones para empresas en Puerto Cisnes?
          <span class="faq-icon text-fern text-[1.3rem] transition-transform duration-500">+</span>
        </button>
        <div class="faq-answer grid grid-rows-[0fr] transition-all duration-500 ease-[cubic-bezier(0.22,1,0.36,1)]">
          <div class="overflow-hidden">
            <p class="px-7 pb-6 text-white/[0.6] text-[0.9rem] leading-[1.8]">
              Sí. Contamos con convenios de alojamiento y alimentación para empresas del sector salmonero, constructoras y organismos públicos en la Región de Aysén. Ofrecemos pensión completa, adaptación a turnos 14×14, facturación mensual y cupos coordinados.
            </p>
          </div>
        </div>
      </div>

      <!-- ITEM -->
      <div class="faq-item bg-white/[0.025] border border-white/[0.06] rounded-[18px] overflow-hidden">
        <button class="faq-question w-full px-7 py-5 flex justify-between items-center text-snow text-[0.95rem]">
          ¿Atienden licitaciones de alimentación del Estado en Aysén?
          <span class="faq-icon text-fern text-[1.3rem] transition-transform duration-500">+</span>
        </button>
        <div class="faq-answer grid grid-rows-[0fr] transition-all duration-500 ease-[cubic-bezier(0.22,1,0.36,1)]">
          <div class="overflow-hidden">
            <p class="px-7 pb-6 text-white/[0.6] text-[0.9rem] leading-[1.8]">
              Sí. Contamos con experiencia en licitaciones y contratos de alimentación para organismos públicos en la Región de Aysén. Gestionamos servicios de pensión completa, colaciones y almuerzos para equipos de trabajo.
            </p>
          </div>
        </div>
      </div>

      <!-- ITEM -->
      <div class="faq-item bg-white/[0.025] border border-white/[0.06] rounded-[18px] overflow-hidden">
        <button class="faq-question w-full px-7 py-5 flex justify-between items-center text-snow text-[0.95rem]">
          ¿Qué incluye la pensión completa en el Hostal El Monchito?
          <span class="faq-icon text-fern text-[1.3rem] transition-transform duration-500">+</span>
        </button>
        <div class="faq-answer grid grid-rows-[0fr] transition-all duration-500 ease-[cubic-bezier(0.22,1,0.36,1)]">
          <div class="overflow-hidden">
            <p class="px-7 pb-6 text-white/[0.6] text-[0.9rem] leading-[1.8]">
              La pensión completa incluye alojamiento en habitación individual o doble, además de desayuno, almuerzo y cena elaborados con productos frescos de la zona.
            </p>
          </div>
        </div>
      </div>

      <!-- ITEM -->
      <div class="faq-item bg-white/[0.025] border border-white/[0.06] rounded-[18px] overflow-hidden">
        <button class="faq-question w-full px-7 py-5 flex justify-between items-center text-snow text-[0.95rem]">
          ¿Cómo puedo reservar o solicitar un convenio?
          <span class="faq-icon text-fern text-[1.3rem] transition-transform duration-500">+</span>
        </button>
        <div class="faq-answer grid grid-rows-[0fr] transition-all duration-500 ease-[cubic-bezier(0.22,1,0.36,1)]">
          <div class="overflow-hidden">
            <p class="px-7 pb-6 text-white/[0.6] text-[0.9rem] leading-[1.8]">
              Puede contactarnos por WhatsApp al +56 9 6224 9178, escribirnos a hostalmonchito2023@gmail.cl o mediante el formulario de contacto. Para convenios empresariales solicitamos datos de la empresa, número de personas, fechas y tipo de servicio.
            </p>
          </div>
        </div>
      </div>

      <!-- ITEM -->
      <div class="faq-item bg-white/[0.025] border border-white/[0.06] rounded-[18px] overflow-hidden">
        <button class="faq-question w-full px-7 py-5 flex justify-between items-center text-snow text-[0.95rem]">
          ¿Dónde está ubicado el hostal y cómo llegar?
          <span class="faq-icon text-fern text-[1.3rem] transition-transform duration-500">+</span>
        </button>
        <div class="faq-answer grid grid-rows-[0fr] transition-all duration-500 ease-[cubic-bezier(0.22,1,0.36,1)]">
          <div class="overflow-hidden">
            <p class="px-7 pb-6 text-white/[0.6] text-[0.9rem] leading-[1.8]">
              Estamos en Calle Aguada de Dolores 1, Puerto Cisnes, Región de Aysén, en la Carretera Austral. Se puede acceder desde Coyhaique por la Ruta 7 o mediante servicio de ferry.
            </p>
          </div>
        </div>
      </div>

      <!-- ITEM -->
      <div class="faq-item bg-white/[0.025] border border-white/[0.06] rounded-[18px] overflow-hidden">
        <button class="faq-question w-full px-7 py-5 flex justify-between items-center text-snow text-[0.95rem]">
          ¿El restaurante atiende a público general o solo a huéspedes?
          <span class="faq-icon text-fern text-[1.3rem] transition-transform duration-500">+</span>
        </button>
        <div class="faq-answer grid grid-rows-[0fr] transition-all duration-500 ease-[cubic-bezier(0.22,1,0.36,1)]">
          <div class="overflow-hidden">
            <p class="px-7 pb-6 text-white/[0.6] text-[0.9rem] leading-[1.8]">
              Nuestro restaurante atiende tanto a huéspedes como al público general. Ofrecemos cocina patagónica a la carta, menús diarios para empresas y trabajadores, además de pizzas, pastas y eventos privados con reserva previa.
            </p>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  document.querySelectorAll(".faq-question").forEach((btn) => {
    btn.addEventListener("click", () => {
      const item = btn.closest(".faq-item");
      const isOpen = item.classList.contains("open");

      document.querySelectorAll(".faq-item").forEach((i) => {
        i.classList.remove("open");
        i.querySelector(".faq-answer").style.gridTemplateRows = "0fr";
        i.querySelector(".faq-icon").style.transform = "rotate(0deg)";
        i.querySelector(".faq-question").setAttribute("aria-expanded", "false");
      });

      if (!isOpen) {
        item.classList.add("open");
        item.querySelector(".faq-answer").style.gridTemplateRows = "1fr";
        item.querySelector(".faq-icon").style.transform = "rotate(45deg)";
        btn.setAttribute("aria-expanded", "true");
      }
    });
  });
</script>