---
import BaseHead from "../components/landing/BaseHead.astro";
import '../styles/globals.css';

const error = Astro.url.searchParams.get('error');
---
<!doctype html>
<html lang="es-CL" class="scroll-smooth">
  <head>
    <BaseHead />
    <title>Iniciar Sesión — Hostal El Monchito</title>
  </head>
  <body class="bg-ink text-cloud font-sans flex items-center justify-center min-h-screen">

    <div class="w-full max-w-sm px-6">

      <!-- Brand -->
      <div class="text-center mb-10">
        <a href="/" class="font-serif text-3xl font-light text-snow no-underline tracking-[0.02em]">
          El <em class="text-fern italic">Monchito</em>
        </a>
        <p class="mt-2 text-white/40 text-sm tracking-wide">Panel de administración</p>
      </div>

      <!-- Card -->
      <div class="bg-white/[0.04] border border-white/10 rounded-2xl p-8 backdrop-blur-sm shadow-[0_8px_40px_rgba(0,0,0,0.4)]">

        <h1 class="text-lg font-medium text-snow mb-1">Iniciar sesión</h1>
        <p class="text-white/40 text-sm mb-7">Solo para administradores del hostal</p>

        {(error === 'unauthorized' || error === 'AccessDenied') && (
          <div class="mb-6 px-4 py-3 bg-red-500/10 border border-red-500/20 rounded-xl text-red-400 text-sm">
            Esta cuenta no tiene acceso al panel.
          </div>
        )}

        {error === 'auth' && (
          <div class="mb-6 px-4 py-3 bg-red-500/10 border border-red-500/20 rounded-xl text-red-400 text-sm">
            Error al autenticar. Inténtalo de nuevo.
          </div>
        )}

        <button
          id="google-signin"
          type="button"
          class="flex items-center justify-center gap-3 w-full
                 bg-white hover:bg-white/90 active:scale-[0.98]
                 text-gray-900 font-medium
                 px-6 py-3.5 rounded-xl
                 transition-all duration-200
                 no-underline text-sm shadow-sm cursor-pointer"
        >
          <!-- Google logo -->
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M17.64 9.2045c0-.6381-.0573-1.2518-.1636-1.8409H9v3.4814h4.8436c-.2086 1.125-.8427 2.0782-1.7959 2.7164v2.2581h2.9087c1.7018-1.5668 2.6836-3.874 2.6836-6.615z" fill="#4285F4"/>
            <path d="M9 18c2.43 0 4.4673-.806 5.9564-2.1805l-2.9087-2.2581c-.8059.54-1.8368.859-3.0477.859-2.3441 0-4.328-1.5836-5.036-3.711H.9574v2.3318C2.4382 15.9832 5.4818 18 9 18z" fill="#34A853"/>
            <path d="M3.964 10.71c-.18-.54-.2822-1.1168-.2822-1.71s.1023-1.17.2822-1.71V4.9582H.9574C.3477 6.1731 0 7.5477 0 9s.3477 2.8268.9574 4.0418L3.964 10.71z" fill="#FBBC05"/>
            <path d="M9 3.5795c1.3214 0 2.5077.4541 3.4405 1.346l2.5813-2.5814C13.4632.8918 11.426 0 9 0 5.4818 0 2.4382 2.0168.9574 4.9582L3.964 7.29C4.672 5.1627 6.6559 3.5795 9 3.5795z" fill="#EA4335"/>
          </svg>
          Continuar con Google
        </button>

        <script>
          import { signIn } from "auth-astro/client";
          document.getElementById("google-signin")?.addEventListener("click", () => {
            signIn("google", { callbackUrl: "/Dashboard" });
          });
        </script>
      </div>

      <div class="text-center mt-6">
        <a href="/" class="text-white/30 hover:text-white/60 transition-colors text-xs no-underline">
          ← Volver al sitio
        </a>
      </div>

    </div>
  </body>
</html>
