      color: rgba(255,255,255,.45); text-decoration: none;
      transition: all .25s var(--ease);
      box-shadow: var(--shadow-sm);
    }
    .social-icon:hover {
      border-color: var(--fern);
      color: var(--fern);
      background: rgba(107,143,94,.1);
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(107,143,94,.2);
    }

    .footer-heading {
      color: var(--fern); font-size: .62rem;
      letter-spacing: .22em; text-transform: uppercase; margin-bottom: 1.4rem;
    }
    .footer-links { list-style: none; display: flex; flex-direction: column; gap: .65rem; }
