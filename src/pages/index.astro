---
import BlogSection from "../components/landing/BlogSection.astro";
import Services from "../components/landing/Services.astro";
import Testimonios from "../components/landing/Testimonios.astro";
import About from "../components/landing/About.astro";
import Footer from "../components/landing/Footer.astro";
import SocialSidebar from "../../src/components/landing/SocialSidebar.astro";
import Whatsapp from "../components/landing/Whatsapp.astro";
import Hero from "../components/landing/Hero.astro";
import Navbar from "../components/landing/Navbar.astro";
import BaseHead from "../components/landing/BaseHead.astro";
import Gallery from "../components/landing/Gallery.astro";
import FAQ from "../components/landing/FAQ.astro";
---

<!doctype html>
<html lang="es-CL" class="scroll-smooth">
  <head>
    <BaseHead />
  </head>

  <body class="bg-ink text-cloud font-sans overflow-x-hidden leading-relaxed">
    
    <Navbar />

    <Hero />

    <About />

    <Services />

    <Gallery />

    <FAQ />

    <BlogSection />

    <Testimonios />

    <Footer />

    <Whatsapp />

    <SocialSidebar />

    <!-- ===== GALLERY RESPONSIVE (mobile override) ===== -->
    <style>
      /* Navbar scrolled state — Tailwind no puede manejar estado JS dinámico */
      #navbar.scrolled {
        background: rgba(20, 20, 18, 0.88);
        backdrop-filter: blur(20px) saturate(180%);
        -webkit-backdrop-filter: blur(20px) saturate(180%);
        padding-top: 1rem;
        padding-bottom: 1rem;
        box-shadow:
          0 1px 0 rgba(255, 255, 255, 0.06),
          0 8px 32px rgba(0, 0, 0, 0.4);
      }

      /* Mobile menu open */
      #mobile-menu.open {
        display: flex;
        animation: float-in 0.35s cubic-bezier(0.16, 1, 0.3, 1);
      }

      /* Safe area insets */
      @supports (padding: max(0px)) {
        #navbar {
          padding-left: max(2.5rem, env(safe-area-inset-left));
          padding-right: max(2.5rem, env(safe-area-inset-right));
        }
        #wa-float {
          right: max(2rem, env(safe-area-inset-right));
          bottom: max(2rem, env(safe-area-inset-bottom));
        }
        footer .max-w-\[1160px\]:last-child {
          padding-left: max(1.25rem, env(safe-area-inset-left));
          padding-right: max(1.25rem, env(safe-area-inset-right));
          padding-bottom: max(1.5rem, env(safe-area-inset-bottom));
        }
      }
    </style>
  </body>
</html>
