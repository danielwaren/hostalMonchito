  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --forest:  #1a2e1a;
      --moss:    #2d4a2d;
      --sage:    #4a6741;
      --fern:    #6b8f5e;
      --fern2:   #82a874;
      --glacier: #4a7a8a;
      --ice:     #7fb3c0;
      --mist:    #b8d4db;
      --cloud:   #e8e4df;
      --snow:    #faf8f5;
      --ink:     #1a1a18;
      --inkdeep: #111110;
      --inkbase: #161614;
      --footer:  #0c0d0c;
      --wa:      #25D366;
      --shadow-sm:   0 2px 12px rgba(0,0,0,.35), 0 1px 3px rgba(0,0,0,.2);
      --shadow-md:   0 8px 32px rgba(0,0,0,.45), 0 2px 8px rgba(0,0,0,.25);
      --shadow-lg:   0 20px 60px rgba(0,0,0,.55), 0 4px 16px rgba(0,0,0,.3);
      --shadow-fern: 0 8px 32px rgba(107,143,94,.18), 0 2px 8px rgba(107,143,94,.1);
      --shadow-glow: 0 0 40px rgba(107,143,94,.12);
      --r-sm: 10px; --r-md: 16px; --r-lg: 24px; --r-xl: 32px;
      --ease: cubic-bezier(.16,1,.3,1);
    }

    html { background: var(--ink); color: var(--cloud); font-family: 'DM Sans', sans-serif; -webkit-text-size-adjust: 100%; -webkit-tap-highlight-color: transparent; }
    body { background: var(--ink); overflow-x: hidden; line-height: 1.6; }

    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-track { background: var(--ink); }
    ::-webkit-scrollbar-thumb { background: var(--sage); border-radius: 2px; }

    .font-serif { font-family: 'Cormorant Garamond', serif; }
    .font-sans  { font-family: 'DM Sans', sans-serif; }

    @keyframes pulse-dot  { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.4;transform:scale(.7)} }
    @keyframes scroll-ln  { 0%,100%{transform:scaleY(1);opacity:.8} 50%{transform:scaleY(.4);opacity:.3} }
    @keyframes wa-pulse   { 0%,100%{box-shadow:0 4px 24px rgba(37,211,102,.4)} 50%{box-shadow:0 4px 36px rgba(37,211,102,.7),0 0 0 10px rgba(37,211,102,.08)} }
    @keyframes float-in   { from{opacity:0;transform:translateY(16px)} to{opacity:1;transform:none} }

    .pulse-dot  { animation: pulse-dot 2s ease-in-out infinite; }
    .scroll-line{ animation: scroll-ln 2s ease-in-out infinite; }
    .wa-btn     { animation: wa-pulse 2.5s ease-in-out infinite; transition: transform .25s var(--ease); }
    .wa-btn:hover{ animation: none; transform: scale(1.12); box-shadow: 0 8px 32px rgba(37,211,102,.55); }

    .reveal       { opacity:0; transform:translateY(36px);  transition: opacity .85s var(--ease), transform .85s var(--ease); }
    .reveal-left  { opacity:0; transform:translateX(-44px); transition: opacity .85s var(--ease), transform .85s var(--ease); }
    .reveal-right { opacity:0; transform:translateX(44px);  transition: opacity .85s var(--ease), transform .85s var(--ease); }
    .reveal.visible, .reveal-left.visible, .reveal-right.visible { opacity:1; transform:none; }
    .delay-1 { transition-delay:.12s; }
    .delay-2 { transition-delay:.24s; }
    .delay-3 { transition-delay:.36s; }
    .delay-4 { transition-delay:.48s; }

    /* NAVBAR */
    #navbar {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 1.5rem 2.5rem;
      transition: all .4s var(--ease);
    }
    #navbar.scrolled {
      background: rgba(20,20,18,.88);
      backdrop-filter: blur(20px) saturate(180%);
      -webkit-backdrop-filter: blur(20px) saturate(180%);
      padding: 1rem 2.5rem;
      box-shadow: 0 1px 0 rgba(255,255,255,.06), 0 8px 32px rgba(0,0,0,.4);
    }
    .nav-logo { font-family: 'Cormorant Garamond', serif; font-size: 1.5rem; font-weight: 300; color: var(--snow); text-decoration: none; letter-spacing: .02em; transition: opacity .2s; }
    .nav-logo:hover { opacity: .8; }
    .nav-logo em { color: var(--fern); font-style: italic; }
    .nav-links { display: flex; gap: 2.5rem; list-style: none; }
    .nav-links a { color: rgba(255,255,255,.65); text-decoration: none; font-size: .75rem; letter-spacing: .12em; text-transform: uppercase; transition: color .2s; position: relative; }
    .nav-links a::after { content: ''; position: absolute; bottom: -3px; left: 0; right: 0; height: 1px; background: var(--fern); transform: scaleX(0); transition: transform .3s var(--ease); }
    .nav-links a:hover { color: var(--snow); }
    .nav-links a:hover::after { transform: scaleX(1); }
    .nav-actions { display: flex; align-items: center; gap: .6rem; }
    .btn-ghost { display: inline-flex; align-items: center; gap: .4rem; color: rgba(255,255,255,.65); text-decoration: none; border: 1px solid rgba(255,255,255,.2); padding: .5rem 1.1rem; border-radius: var(--r-sm); font-size: .72rem; letter-spacing: .08em; text-transform: uppercase; transition: all .25s var(--ease); backdrop-filter: blur(8px); }
    .btn-ghost:hover { color: var(--snow); border-color: rgba(255,255,255,.5); background: rgba(255,255,255,.06); }
    .btn-primary { display: inline-flex; align-items: center; gap: .45rem; color: var(--snow); text-decoration: none; background: var(--sage); padding: .55rem 1.3rem; border-radius: var(--r-sm); font-size: .72rem; font-weight: 500; letter-spacing: .1em; text-transform: uppercase; transition: all .25s var(--ease); box-shadow: var(--shadow-fern); }
    .btn-primary:hover { background: var(--fern2); transform: translateY(-1px); box-shadow: 0 12px 36px rgba(107,143,94,.3); }
    #hamburger-btn { display: none; flex-direction: column; gap: 5px; background: none; border: 1px solid rgba(255,255,255,.2); border-radius: var(--r-sm); cursor: pointer; padding: .55rem .65rem; transition: border-color .2s; }
    #hamburger-btn span { width: 20px; height: 1.5px; background: var(--snow); display: block; transition: transform .3s var(--ease), opacity .3s; }
    #hamburger-btn:hover { border-color: rgba(255,255,255,.5); }

    /* MOBILE MENU */
    #mobile-menu { display: none; position: fixed; inset: 0; z-index: 200; background: rgba(10,11,10,.97); backdrop-filter: blur(24px) saturate(180%); -webkit-backdrop-filter: blur(24px) saturate(180%); flex-direction: column; align-items: center; justify-content: center; gap: .5rem; }
    #mobile-menu.open { display: flex; animation: float-in .35s var(--ease); }
    .mobile-close { position: absolute; top: 1.5rem; right: 1.5rem; background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.15); border-radius: 50%; width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; color: var(--snow); font-size: 1.1rem; cursor: pointer; transition: background .2s; }
    .mobile-close:hover { background: rgba(255,255,255,.15); }
    .mobile-nav a { font-family: 'Cormorant Garamond', serif; color: rgba(255,255,255,.7); text-decoration: none; font-size: 2.6rem; font-weight: 300; display: block; text-align: center; padding: .4rem 2rem; transition: color .3s, transform .3s; }
    .mobile-nav a:hover { color: var(--snow); transform: translateX(8px); }
    .mobile-divider { width: 1px; height: 40px; background: linear-gradient(to bottom, transparent, rgba(255,255,255,.2), transparent); margin: .5rem 0; }

    /* HERO */
    #hero { position: relative; height: 100svh; min-height: 620px; display: flex; align-items: center; overflow: hidden; }
    #parallax-bg { position: absolute; inset: -10%; z-index: 0; }
    #parallax-bg img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .hero-overlay { position: absolute; inset: 0; z-index: 1; background: radial-gradient(ellipse at 30% 50%, rgba(26,46,26,.7) 0%, transparent 70%), linear-gradient(135deg, rgba(20,20,18,.8) 0%, rgba(20,20,18,.3) 60%, rgba(74,122,138,.25) 100%); }
    .hero-content { position: relative; z-index: 2; padding: 0 2.5rem; max-width: min(800px, 92vw); }
    .hero-badge { display: inline-flex; align-items: center; gap: .5rem; background: rgba(255,255,255,.07); border: 1px solid rgba(255,255,255,.12); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); padding: .4rem 1rem; border-radius: 100px; margin-bottom: 1.8rem; }
    .hero-badge span { color: var(--mist); font-size: .68rem; letter-spacing: .18em; text-transform: uppercase; }
    .hero-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(2.8rem, 8vw, 5.5rem); font-weight: 300; color: var(--snow); line-height: 1.05; margin-bottom: 1.4rem; }
    .hero-title em { font-style: italic; color: var(--mist); }
    .hero-sub { color: rgba(255,255,255,.68); font-size: clamp(.88rem, 2vw, 1rem); font-weight: 300; line-height: 1.75; max-width: 460px; margin-bottom: 2.5rem; }
    .hero-ctas { display: flex; flex-wrap: wrap; gap: .9rem; }
    .btn-hero-primary { display: inline-flex; align-items: center; gap: .55rem; background: var(--sage); color: var(--snow); text-decoration: none; padding: .85rem 2rem; border-radius: var(--r-md); font-size: .78rem; font-weight: 500; letter-spacing: .1em; text-transform: uppercase; transition: all .3s var(--ease); box-shadow: 0 4px 20px rgba(107,143,94,.35), 0 1px 3px rgba(0,0,0,.3); }
    .btn-hero-primary:hover { background: var(--fern2); transform: translateY(-2px); box-shadow: 0 12px 40px rgba(107,143,94,.45), 0 2px 8px rgba(0,0,0,.3); }
    .btn-hero-secondary { display: inline-flex; align-items: center; gap: .55rem; border: 1px solid rgba(255,255,255,.28); color: var(--snow); text-decoration: none; padding: .85rem 2rem; border-radius: var(--r-md); font-size: .78rem; font-weight: 400; letter-spacing: .1em; text-transform: uppercase; transition: all .3s var(--ease); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px); }
    .btn-hero-secondary:hover { background: rgba(255,255,255,.08); border-color: rgba(255,255,255,.5); transform: translateY(-2px); }
    .hero-scroll-hint { position: absolute; bottom: 2.5rem; left: 50%; transform: translateX(-50%); display: flex; flex-direction: column; align-items: center; gap: .5rem; color: rgba(255,255,255,.45); font-size: .62rem; letter-spacing: .2em; text-transform: uppercase; z-index: 2; }

    /* WEATHER */
    #weather-widget { position: absolute; top: 50%; right: 2.5rem; transform: translateY(-50%); z-index: 3; background: rgba(18,18,16,.65); backdrop-filter: blur(20px) saturate(160%); -webkit-backdrop-filter: blur(20px) saturate(160%); border: 1px solid rgba(255,255,255,.1); border-radius: var(--r-lg); padding: 1.4rem 1.6rem; min-width: 185px; box-shadow: var(--shadow-md), inset 0 1px 0 rgba(255,255,255,.08); }
    #weather-widget .label { color: var(--fern); font-size: .58rem; letter-spacing: .22em; text-transform: uppercase; margin-bottom: .9rem; display: flex; align-items: center; gap: .4rem; }

    /* SECTIONS */
    .section { padding: clamp(4rem, 8vw, 7rem) clamp(1.25rem, 4vw, 3rem); }
    .container { max-width: 1160px; margin: 0 auto; }
    .section-label { color: var(--fern); font-size: .62rem; font-weight: 500; letter-spacing: .28em; text-transform: uppercase; margin-bottom: 1rem; display: flex; align-items: center; gap: .5rem; }
    .section-label::before { content: ''; display: block; width: 24px; height: 1px; background: var(--fern); }
    .section-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(2rem, 5vw, 3rem); font-weight: 300; color: var(--snow); line-height: 1.1; }
    .section-title em { font-style: italic; color: var(--fern); }

    /* ABOUT */
    #about { background: var(--ink); }
    .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2.5rem, 6vw, 5rem); align-items: center; }
    .about-img-wrap { position: relative; }
    .about-img-wrap::before { content: ''; position: absolute; inset: -1px; border-radius: calc(var(--r-xl) + 2px); background: linear-gradient(135deg, rgba(107,143,94,.3) 0%, rgba(74,122,138,.15) 100%); z-index: -1; }
    .about-img-wrap img { width: 100%; height: 500px; object-fit: cover; border-radius: var(--r-xl); display: block; box-shadow: var(--shadow-lg); }
    .about-accent { position: absolute; bottom: -1.2rem; right: -1.2rem; width: 160px; height: 160px; background: linear-gradient(135deg, var(--moss), var(--forest)); border-radius: var(--r-lg); z-index: -2; box-shadow: var(--shadow-md); }
    .about-badge { position: absolute; top: 1.5rem; left: 1.5rem; background: rgba(18,18,16,.8); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border: 1px solid rgba(107,143,94,.3); border-radius: var(--r-md); padding: .7rem 1rem; box-shadow: var(--shadow-md), var(--shadow-fern); }
    .about-badge .rating { font-family: 'Cormorant Garamond', serif; font-size: 1.6rem; color: var(--snow); line-height: 1; }
    .about-badge .stars  { color: var(--fern); font-size: .7rem; margin: .1rem 0; }
    .about-badge .label  { color: rgba(255,255,255,.5); font-size: .6rem; letter-spacing: .1em; text-transform: uppercase; }
    .about-text p { color: rgba(255,255,255,.58); line-height: 1.85; font-size: .93rem; margin-bottom: 1.1rem; }
    .stats-row { display: flex; gap: 2.5rem; margin-top: 2.5rem; padding-top: 2rem; border-top: 1px solid rgba(255,255,255,.07); }
    .stat-val { font-family: 'Cormorant Garamond', serif; font-size: 2.4rem; font-weight: 300; color: var(--fern); line-height: 1; }
    .stat-lbl { color: rgba(255,255,255,.38); font-size: .65rem; letter-spacing: .1em; text-transform: uppercase; margin-top: .3rem; }

    /* SERVICES */
    #services { background: var(--inkbase); }
    .services-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; margin-top: 3.5rem; }
    .service-card { background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.07); border-radius: var(--r-xl); overflow: hidden; transition: transform .4s var(--ease), box-shadow .4s var(--ease), border-color .4s; box-shadow: 0 4px 24px rgba(0,0,0,.3), 0 1px 4px rgba(0,0,0,.2); }
    .service-card:hover { transform: translateY(-6px); box-shadow: 0 24px 64px rgba(0,0,0,.45), 0 8px 20px rgba(0,0,0,.25), var(--shadow-glow); border-color: rgba(107,143,94,.2); }
    .card-img-wrap { overflow: hidden; }
    .card-img-wrap img { width: 100%; height: 240px; object-fit: cover; display: block; filter: brightness(.8) saturate(.9); transition: transform .7s var(--ease), filter .5s; }
    .service-card:hover .card-img-wrap img { transform: scale(1.07); filter: brightness(.95) saturate(1.05); }
    .card-body { padding: 1.8rem 1.8rem 2rem; }
    .card-icon { width: 38px; height: 38px; border-radius: var(--r-sm); display: flex; align-items: center; justify-content: center; font-size: 1rem; margin-bottom: 1.1rem; }
    .card-icon-fern    { background: rgba(107,143,94,.15); border: 1px solid rgba(107,143,94,.25); }
    .card-icon-glacier { background: rgba(74,122,138,.15); border: 1px solid rgba(74,122,138,.25); }
    .card-title { font-family: 'Cormorant Garamond', serif; font-size: 1.3rem; font-weight: 400; color: var(--snow); margin-bottom: .6rem; }
    .card-desc { color: rgba(255,255,255,.48); font-size: .82rem; line-height: 1.72; margin-bottom: 1.1rem; }
    .card-features { list-style: none; margin-bottom: 1.3rem; display: flex; flex-direction: column; gap: .38rem; }
    .card-features li { color: rgba(255,255,255,.42); font-size: .76rem; display: flex; align-items: center; gap: .5rem; }
    .card-features li .check { color: var(--fern); flex-shrink: 0; }
    .card-features li .check-blue { color: var(--ice); flex-shrink: 0; }
    .card-cta { color: var(--fern); font-size: .7rem; letter-spacing: .15em; text-transform: uppercase; text-decoration: none; display: inline-flex; align-items: center; gap: .4rem; transition: gap .3s var(--ease), color .2s; }
    .card-cta.blue { color: var(--ice); }
    .card-cta:hover { gap: .7rem; color: var(--fern2); }
    .card-cta.blue:hover { color: var(--mist); }
    .badge-tag { position: absolute; top: 1rem; right: 1rem; z-index: 2; background: var(--glacier); color: var(--snow); font-size: .58rem; letter-spacing: .15em; text-transform: uppercase; padding: .3rem .75rem; border-radius: 100px; font-weight: 500; box-shadow: var(--shadow-sm); }

    /* GALLERY */
    #gallery { background: var(--ink); }
    .gallery-grid { display: grid; grid-template-columns: repeat(12, 1fr); grid-template-rows: 260px 260px; gap: 8px; margin-top: 3rem; }
    .g1 { grid-column: 1/6;  grid-row: 1/2; }
    .g2 { grid-column: 6/9;  grid-row: 1/2; }
    .g3 { grid-column: 9/13; grid-row: 1/3; }
    .g4 { grid-column: 1/4;  grid-row: 2/3; }
    .g5 { grid-column: 4/6;  grid-row: 2/3; }
    .g6 { grid-column: 6/9;  grid-row: 2/3; }
    .g-item { overflow: hidden; border-radius: var(--r-md); box-shadow: var(--shadow-md); position: relative; }
    .g-item::after { content: ''; position: absolute; inset: 0; background: linear-gradient(to bottom, transparent 50%, rgba(0,0,0,.4)); opacity: 0; transition: opacity .4s; pointer-events: none; }
    .g-item:hover::after { opacity: 1; }
    .g-item img { width: 100%; height: 100%; object-fit: cover; display: block; filter: brightness(.82) saturate(.88); transition: transform .75s var(--ease), filter .45s; }
    .g-item:hover img { transform: scale(1.07); filter: brightness(.95) saturate(1.05); }

    /* TESTIMONIALS */
    #testimonials { background: var(--inkdeep); }
    .testimonials-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; margin-top: 3.5rem; }
    .testi-card { background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.07); border-radius: var(--r-xl); padding: 2rem; transition: transform .35s var(--ease), box-shadow .35s var(--ease), border-color .35s; box-shadow: 0 4px 20px rgba(0,0,0,.3); }
    .testi-card:hover { transform: translateY(-4px); box-shadow: 0 16px 48px rgba(0,0,0,.4), 0 4px 12px rgba(0,0,0,.2); border-color: rgba(107,143,94,.18); }
    .testi-stars { color: var(--fern); font-size: .78rem; letter-spacing: .1em; margin-bottom: 1.1rem; }
    .testi-quote { font-family: 'Cormorant Garamond', serif; font-size: 1.05rem; font-weight: 300; font-style: italic; color: var(--cloud); line-height: 1.72; margin-bottom: 1.5rem; }
    .testi-author { display: flex; align-items: center; gap: .8rem; }
    .testi-avatar { width: 38px; height: 38px; border-radius: 50%; flex-shrink: 0; background: var(--moss); display: flex; align-items: center; justify-content: center; font-family: 'Cormorant Garamond', serif; font-size: 1rem; color: var(--snow); box-shadow: var(--shadow-sm); }
    .testi-name  { font-size: .82rem; font-weight: 500; color: var(--snow); }
    .testi-meta  { font-size: .7rem; color: rgba(255,255,255,.38); margin-top: .15rem; }

    /* FAQ */
    #faq { background: var(--ink); }
    .faq-list { margin-top: 2.5rem; display: flex; flex-direction: column; gap: 1rem; }
    .faq-item { background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.07); border-radius: var(--r-md); overflow: hidden; }
    .faq-question { width: 100%; text-align: left; background: none; border: none; cursor: pointer; padding: 1.3rem 1.5rem; display: flex; justify-content: space-between; align-items: center; color: var(--snow); font-size: .92rem; font-family: 'DM Sans', sans-serif; transition: background .2s; }
    .faq-question:hover { background: rgba(255,255,255,.03); }
    .faq-question .faq-icon { color: var(--fern); font-size: 1.2rem; flex-shrink: 0; transition: transform .3s var(--ease); }
    .faq-item.open .faq-icon { transform: rotate(45deg); }
    .faq-answer { max-height: 0; overflow: hidden; transition: max-height .4s var(--ease), padding .3s; padding: 0 1.5rem; }
    .faq-item.open .faq-answer { max-height: 300px; padding: 0 1.5rem 1.3rem; }
    .faq-answer p { color: rgba(255,255,255,.55); font-size: .88rem; line-height: 1.75; }

    /* ================================================================
       BLOG SECTION
    ================================================================ */
    #blog { background: var(--inkbase); }

    .blog-header {
      display: flex; flex-wrap: wrap;
      align-items: flex-end; justify-content: space-between;
      gap: 1.5rem; margin-bottom: 3.5rem;
    }

    .btn-outline-fern {
      display: inline-flex; align-items: center; gap: .45rem;
      color: var(--fern); text-decoration: none;
      border: 1px solid rgba(107,143,94,.35);
      padding: .55rem 1.3rem; border-radius: var(--r-sm);
      font-size: .7rem; letter-spacing: .12em; text-transform: uppercase;
      transition: all .25s var(--ease); white-space: nowrap;
    }
    .btn-outline-fern:hover {
      background: rgba(107,143,94,.1);
      border-color: var(--fern);
      color: var(--fern2);
    }

    /* Grid principal: 1 card destacada + 2 normales en fila 1,
       3 normales en fila 2  */
    .blog-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }

    /* Card base */
    .blog-card {
      background: rgba(255,255,255,.03);
      border: 1px solid rgba(255,255,255,.07);
      border-radius: var(--r-xl);
      overflow: hidden;
      display: flex; flex-direction: column;
      transition: transform .4s var(--ease), box-shadow .4s var(--ease), border-color .4s;
      box-shadow: 0 4px 24px rgba(0,0,0,.3);
    }
    .blog-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 24px 64px rgba(0,0,0,.45), 0 8px 20px rgba(0,0,0,.25), var(--shadow-glow);
      border-color: rgba(107,143,94,.2);
    }

    /* Card destacada ocupa 2 columnas */
    .blog-card--featured {
      grid-column: span 2;
    }

    .blog-card__img-wrap {
      overflow: hidden; position: relative; flex-shrink: 0;
    }
    .blog-card__img-wrap img {
      width: 100%; object-fit: cover; display: block;
      filter: brightness(.82) saturate(.9);
      transition: transform .7s var(--ease), filter .5s;
    }
    .blog-card--featured .blog-card__img-wrap img { height: 300px; }
    .blog-card:not(.blog-card--featured) .blog-card__img-wrap img { height: 200px; }
    .blog-card:hover .blog-card__img-wrap img { transform: scale(1.06); filter: brightness(.95) saturate(1.05); }

    .blog-card__tag {
      position: absolute; top: 1rem; left: 1rem; z-index: 2;
      font-size: .58rem; font-weight: 500;
      letter-spacing: .15em; text-transform: uppercase;
      padding: .28rem .75rem; border-radius: 100px;
      color: var(--snow); box-shadow: var(--shadow-sm);
    }
    .blog-card__tag--green   { background: var(--sage); }
    .blog-card__tag--blue    { background: var(--glacier); }

    .blog-card__body {
      padding: 1.6rem 1.8rem 2rem;
      display: flex; flex-direction: column; flex: 1;
    }

    .blog-card__meta {
      display: flex; align-items: center; gap: .8rem;
      margin-bottom: .9rem;
    }
    .blog-card__date { color: rgba(255,255,255,.38); font-size: .65rem; letter-spacing: .1em; text-transform: uppercase; }
    .blog-card__min  { color: var(--fern); font-size: .65rem; letter-spacing: .1em; text-transform: uppercase; }
    .blog-card__dot  { width: 3px; height: 3px; background: rgba(255,255,255,.2); border-radius: 50%; flex-shrink: 0; }

    .blog-card__title {
      font-family: 'Cormorant Garamond', serif;
      color: var(--snow); font-weight: 300; line-height: 1.2;
      margin-bottom: .75rem;
    }
    .blog-card--featured .blog-card__title { font-size: 1.55rem; }
    .blog-card:not(.blog-card--featured) .blog-card__title { font-size: 1.15rem; }

    .blog-card__excerpt {
      color: rgba(255,255,255,.48); font-size: .82rem;
      line-height: 1.72; flex: 1; margin-bottom: 1.3rem;
    }

    .blog-card__tags {
      display: flex; flex-wrap: wrap; gap: .4rem; margin-bottom: 1.2rem;
    }
    .blog-card__pill {
      font-size: .62rem; padding: .22rem .65rem; border-radius: 100px;
      letter-spacing: .06em;
    }
    .blog-card__pill--green  { background: rgba(107,143,94,.12); border: 1px solid rgba(107,143,94,.22); color: var(--fern); }
    .blog-card__pill--blue   { background: rgba(74,122,138,.12);  border: 1px solid rgba(74,122,138,.22);  color: var(--ice); }

    .blog-card__cta {
      color: var(--fern); font-size: .7rem;
      letter-spacing: .14em; text-transform: uppercase;
      text-decoration: none; display: inline-flex; align-items: center; gap: .4rem;
      transition: gap .3s var(--ease), color .2s; margin-top: auto;
    }
    .blog-card__cta:hover { gap: .7rem; color: var(--fern2); }

    /* FOOTER */
    footer { background: var(--footer); border-top: 1px solid rgba(255,255,255,.05); }
    .footer-grid { display: grid; grid-template-columns: 1.6fr 1fr 1fr 1fr; gap: 3rem; padding: clamp(3rem, 6vw, 5rem) clamp(1.25rem, 4vw, 3rem); max-width: 1160px; margin: 0 auto; }
    .footer-brand { font-family: 'Cormorant Garamond', serif; font-size: 1.6rem; font-weight: 300; color: var(--snow); margin-bottom: 1rem; }
    .footer-brand em { color: var(--fern); font-style: italic; }
    .footer-desc { color: rgba(255,255,255,.38); font-size: .82rem; line-height: 1.72; max-width: 250px; margin-bottom: 1.5rem; }
    .footer-social { display: flex; gap: .6rem; }
    .social-icon { width: 34px; height: 34px; border-radius: var(--r-sm); display: flex; align-items: center; justify-content: center; border: 1px solid rgba(255,255,255,.12); background: rgba(255,255,255,.04); color: rgba(255,255,255,.45); text-decoration: none; transition: all .25s var(--ease); box-shadow: var(--shadow-sm); }
    .social-icon:hover { border-color: var(--fern); color: var(--fern); background: rgba(107,143,94,.1); transform: translateY(-2px); box-shadow: 0 6px 20px rgba(107,143,94,.2); }
    .footer-heading { color: var(--fern); font-size: .62rem; letter-spacing: .22em; text-transform: uppercase; margin-bottom: 1.4rem; }
    .footer-links { list-style: none; display: flex; flex-direction: column; gap: .65rem; }
    .footer-links a { color: rgba(255,255,255,.45); text-decoration: none; font-size: .85rem; transition: color .2s, padding-left .2s; }
    .footer-links a:hover { color: var(--snow); padding-left: 4px; }
    .footer-contact-item { display: flex; align-items: flex-start; gap: .7rem; color: rgba(255,255,255,.42); font-size: .82rem; line-height: 1.5; margin-bottom: .8rem; }
    .footer-contact-item svg { flex-shrink: 0; margin-top: 2px; opacity: .6; }
    .map-wrap { width: 100%; height: 145px; border-radius: var(--r-md); overflow: hidden; border: 1px solid rgba(255,255,255,.08); box-shadow: var(--shadow-sm); margin-top: .5rem; }
    .map-wrap iframe { width: 100%; height: 100%; border: none; filter: grayscale(1) brightness(.7); }
    .footer-bottom { max-width: 1160px; margin: 0 auto; padding: 1.5rem clamp(1.25rem, 4vw, 3rem); border-top: 1px solid rgba(255,255,255,.04); display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 1rem; }
    .footer-bottom p { color: rgba(255,255,255,.22); font-size: .72rem; }

    /* SOCIAL SIDEBAR */
    #social-sidebar { position: fixed; left: 1.5rem; top: 50%; transform: translateY(-50%); z-index: 99; display: flex; flex-direction: column; align-items: center; gap: .6rem; }
    .sidebar-line   { width: 1px; height: 48px; background: linear-gradient(to bottom, transparent, rgba(255,255,255,.18)); }
    .sidebar-line-b { width: 1px; height: 48px; background: linear-gradient(to top,   transparent, rgba(255,255,255,.18)); }

    /* WA FLOAT */
    #wa-float { position: fixed; bottom: 2rem; right: 2rem; z-index: 999; width: 58px; height: 58px; border-radius: 50%; background: var(--wa); display: flex; align-items: center; justify-content: center; text-decoration: none; box-shadow: 0 4px 24px rgba(37,211,102,.45); }
    #wa-float svg { width: 28px; height: 28px; fill: white; }

    /* ================================================================
       RESPONSIVE
    ================================================================ */
    @media (max-width: 1180px) {
      .footer-grid { grid-template-columns: 1fr 1fr; }
      #social-sidebar { display: none; }
    }

    @media (max-width: 1024px) {
      #weather-widget { display: none; }
      .services-grid  { grid-template-columns: 1fr 1fr; }
      .testimonials-grid { grid-template-columns: 1fr 1fr; }
      .about-grid { grid-template-columns: 1fr; gap: 3rem; }
      .about-img-wrap img { height: 380px; }
      .about-accent { display: none; }
      .blog-card--featured { grid-column: span 2; }
      .blog-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @media (max-width: 768px) {
      #navbar { padding: 1.1rem 1.25rem; }
      #navbar.scrolled { padding: .9rem 1.25rem; }
      .nav-links, .nav-actions .btn-ghost, .nav-actions .btn-primary { display: none; }
      #hamburger-btn { display: flex; }
      .hero-content { padding: 0 1.25rem; }
      .hero-ctas { flex-direction: column; gap: .75rem; }
      .btn-hero-primary, .btn-hero-secondary { justify-content: center; }
      .services-grid     { grid-template-columns: 1fr; gap: 1rem; }
      .testimonials-grid { grid-template-columns: 1fr; gap: 1rem; }
      .gallery-grid { grid-template-columns: 1fr 1fr; grid-template-rows: auto; gap: 6px; }
      .g1,.g2,.g3,.g4,.g5,.g6 { grid-column: auto; grid-row: auto; height: 180px; }
      .footer-grid { grid-template-columns: 1fr; gap: 2.5rem; padding: 3rem 1.25rem; }
      .footer-desc { max-width: 100%; }
      .stats-row { gap: 1.5rem; flex-wrap: wrap; }
      #wa-float { bottom: 1.25rem; right: 1.25rem; width: 52px; height: 52px; }
      /* Blog mobile */
      .blog-grid { grid-template-columns: 1fr; }
      .blog-card--featured { grid-column: span 1; }
      .blog-card--featured .blog-card__img-wrap img { height: 220px; }
      .blog-header { flex-direction: column; align-items: flex-start; }
    }

    @media (max-width: 480px) {
      .hero-title { font-size: clamp(2.4rem, 10vw, 3rem); }
      .gallery-grid { grid-template-columns: 1fr; }
      .g1,.g2,.g3,.g4,.g5,.g6 { height: 220px; }
      .testi-card { padding: 1.5rem; }
    }

    @supports (padding: max(0px)) {
      #navbar   { padding-left: max(2.5rem, env(safe-area-inset-left)); padding-right: max(2.5rem, env(safe-area-inset-right)); }
      #wa-float { right: max(2rem, env(safe-area-inset-right)); bottom: max(2rem, env(safe-area-inset-bottom)); }
      footer .footer-bottom { padding-left: max(1.25rem, env(safe-area-inset-left)); padding-right: max(1.25rem, env(safe-area-inset-right)); padding-bottom: max(1.5rem, env(safe-area-inset-bottom)); }
    }
  </style>
</head>
<body>

<!-- ===== NAVBAR ===== -->
<nav id="navbar" role="navigation" aria-label="Menú principal">
  <a href="#" class="nav-logo" aria-label="Hostal El Monchito — Inicio">El <em>Monchito</em></a>
  <ul class="nav-links">
    <li><a href="#about">Nosotros</a></li>
    <li><a href="#services">Servicios</a></li>
    <li><a href="#gallery">Entorno</a></li>
    <li><a href="#testimonials">Reseñas</a></li>
    <li><a href="#faq">Preguntas</a></li>
    <li><a href="#blog">Blog</a></li>
  </ul>
  <div class="nav-actions">
    <a href="/login" class="btn-ghost">
      <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      Iniciar Sesión
    </a>
    <a href="#footer" class="btn-primary">Reservar</a>
    <button id="hamburger-btn" aria-label="Abrir menú móvil" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<!-- ===== MOBILE MENU ===== -->
<div id="mobile-menu" role="dialog" aria-modal="true" aria-label="Menú de navegación">
  <button class="mobile-close" id="mobile-close-btn" aria-label="Cerrar menú">✕</button>
  <nav class="mobile-nav" aria-label="Menú móvil">
    <a href="#about">Nosotros</a>
    <div class="mobile-divider"></div>
    <a href="#services">Servicios</a>
    <div class="mobile-divider"></div>
    <a href="#gallery">Entorno</a>
    <div class="mobile-divider"></div>
    <a href="#testimonials">Reseñas</a>
    <div class="mobile-divider"></div>
    <a href="#faq">Preguntas</a>
    <div class="mobile-divider"></div>
    <a href="#blog">Blog</a>
    <div class="mobile-divider"></div>
    <a href="#footer">Reservar</a>
  </nav>
  <a href="/login" class="btn-ghost" style="margin-top:1.5rem">Iniciar Sesión</a>
</div>

<!-- ===== HERO ===== -->
<section id="hero" aria-label="Bienvenida al Hostal El Monchito">
  <div id="parallax-bg">
    <img src="/header-img.jpg"
         alt="Vista panorámica del fiordo Puyuhuapi desde Puerto Cisnes, Patagonia Chilena"
         width="1920" height="1080" fetchpriority="high" />
  </div>
  <div class="hero-overlay" aria-hidden="true"></div>
  <div class="hero-content">
    <div class="hero-badge reveal" aria-label="Ubicación">
      <div class="pulse-dot" aria-hidden="true" style="width:6px;height:6px;background:var(--fern);border-radius:50%"></div>
      <span>Hospedaje y Alimentación · Puerto Cisnes, Aysén</span>
    </div>
    <h1 class="hero-title reveal delay-1">
      Hospedaje en<br><em>Puerto Cisnes</em><br>con todo incluido.
    </h1>
    <p class="hero-sub reveal delay-2">
      Hostal con pensión completa, restaurante y convenios de alojamiento y colaciones para empresas del sector salmonero, obras públicas y turistas en la Patagonia chilena.
    </p>
    <div class="hero-ctas reveal delay-3">
      <a href="https://wa.me/56912345678?text=Hola%2C%20quisiera%20hacer%20una%20reserva"
         target="_blank" rel="noopener noreferrer" class="btn-hero-primary"
         aria-label="Reservar por WhatsApp">
        <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true"><path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        Reservar Ahora
      </a>
      <a href="#about" class="btn-hero-secondary">
        Conocer Más
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true"><path d="M19 9l-7 7-7-7"/></svg>
      </a>
    </div>
  </div>
  <div id="weather-widget" aria-label="Clima actual en Puerto Cisnes">
    <div class="label">
      <svg width="10" height="10" fill="var(--fern)" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
      Puerto Cisnes
    </div>
    <div id="weather-main-content">
      <p style="font-size:.78rem;color:rgba(255,255,255,.4)">Cargando clima…</p>
    </div>
  </div>
  <div class="hero-scroll-hint" aria-hidden="true">
    <div class="scroll-line" style="width:1px;height:50px;background:linear-gradient(to bottom,rgba(255,255,255,.5),transparent)"></div>
    <span>Explorar</span>
  </div>
</section>

<!-- ===== ABOUT ===== -->
<section id="about" class="section" aria-labelledby="about-title">
  <div class="container">
    <div class="about-grid">
      <div class="about-img-wrap reveal-left">
        <img src="/historia-img.jpg"
             alt="Interior acogedor del Hostal El Monchito, Puerto Cisnes — habitación con calefacción y decoración patagónica"
             loading="lazy" width="600" height="500" />
        <div class="about-accent" aria-hidden="true"></div>
        <div class="about-badge" aria-label="Valoración 4.9 de 5 estrellas">
          <div class="rating">4.9★</div>
          <div class="stars" aria-hidden="true">★★★★★</div>
          <div class="label">Valoración media</div>
        </div>
      </div>
      <div class="about-text reveal-right">
        <p class="section-label">Nuestra Historia</p>
        <h2 id="about-title" class="section-title" style="margin-bottom:1.5rem">
          Hospedaje genuino<br>en el <em>corazón de Aysén</em>
        </h2>
        <p>El <strong>Hostal El Monchito</strong> es el principal referente de <strong>hospedaje y alimentación en Puerto Cisnes</strong>. Con más de 12 años atendiendo a turistas, trabajadores y empresas de la Región de Aysén, ofrecemos pensión completa, restaurante a la carta y convenios de alojamiento para equipos del sector salmonero, constructoras y organismos públicos.</p>
        <p>Ubicados estratégicamente en Puerto Cisnes, somos el punto de partida ideal para explorar la <strong>Carretera Austral</strong> y el <strong>fiordo Puyuhuapi</strong>. Nuestras instalaciones cuentan con habitaciones calefaccionadas, baños privados y una cocina patagónica que trabaja con productos frescos del canal y proveedores locales.</p>
        <p>Para empresas, ofrecemos <strong>convenios de colaciones y alojamiento</strong> con facturación mensual, cupos garantizados y adaptación a turnos rotativos. Contamos con experiencia en <strong>licitaciones de alimentación</strong> para el sector público y privado en Aysén.</p>
