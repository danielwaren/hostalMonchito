    .map-wrap {
      width: 100%; height: 145px;
      border-radius: var(--r-md); overflow: hidden;
      border: 1px solid rgba(255,255,255,.08);
      box-shadow: var(--shadow-sm);
      margin-top: .5rem;
    }
