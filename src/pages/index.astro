    .footer-desc {
      color: rgba(255,255,255,.38); font-size: .82rem;
      line-height: 1.72; max-width: 250px; margin-bottom: 1.5rem;
    }

    .footer-social { display: flex; gap: .6rem; }
    .social-icon {
