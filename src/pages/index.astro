<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="theme-color" content="#141412" />
  <title>Hostal El Monchito — Puerto Cisnes, Patagonia Chilena</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet" />

  <style>
    /* ================================================================
       RESET & ROOT
    ================================================================ */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --forest:  #1a2e1a;
      --moss:    #2d4a2d;
      --sage:    #4a6741;
      --fern:    #6b8f5e;
      --fern2:   #82a874;
      --glacier: #4a7a8a;
      --ice:     #7fb3c0;
      --mist:    #b8d4db;
      --cloud:   #e8e4df;
      --snow:    #faf8f5;
      --ink:     #1a1a18;
      --inkdeep: #111110;
      --inkbase: #161614;
      --footer:  #0c0d0c;
      --wa:      #25D366;

      /* Shadows */
      --shadow-sm:  0 2px 12px rgba(0,0,0,.35), 0 1px 3px rgba(0,0,0,.2);
      --shadow-md:  0 8px 32px rgba(0,0,0,.45), 0 2px 8px rgba(0,0,0,.25);
      --shadow-lg:  0 20px 60px rgba(0,0,0,.55), 0 4px 16px rgba(0,0,0,.3);
      --shadow-fern: 0 8px 32px rgba(107,143,94,.18), 0 2px 8px rgba(107,143,94,.1);
      --shadow-glow: 0 0 40px rgba(107,143,94,.12);

      /* Radii */
      --r-sm: 10px;
      --r-md: 16px;
      --r-lg: 24px;
      --r-xl: 32px;

      /* Transitions */
      --ease: cubic-bezier(.16,1,.3,1);
    }

    html {
      background: var(--ink);
      color: var(--cloud);
      font-family: 'DM Sans', sans-serif;
      -webkit-text-size-adjust: 100%;
      -webkit-tap-highlight-color: transparent;
    }
    body {
      background: var(--ink);
      overflow-x: hidden;
      line-height: 1.6;
    }

    /* ================================================================
       SCROLLBAR
    ================================================================ */
    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-track { background: var(--ink); }
    ::-webkit-scrollbar-thumb { background: var(--sage); border-radius: 2px; }

    /* ================================================================
       TYPOGRAPHY
    ================================================================ */
    .font-serif { font-family: 'Cormorant Garamond', serif; }
    .font-sans  { font-family: 'DM Sans', sans-serif; }

    /* ================================================================
       ANIMATIONS
    ================================================================ */
    @keyframes pulse-dot  { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.4;transform:scale(.7)} }
    @keyframes scroll-ln  { 0%,100%{transform:scaleY(1);opacity:.8} 50%{transform:scaleY(.4);opacity:.3} }
    @keyframes wa-pulse   { 0%,100%{box-shadow:0 4px 24px rgba(37,211,102,.4)} 50%{box-shadow:0 4px 36px rgba(37,211,102,.7),0 0 0 10px rgba(37,211,102,.08)} }
    @keyframes float-in   { from{opacity:0;transform:translateY(16px)} to{opacity:1;transform:none} }
    @keyframes shimmer    { 0%{background-position:-200% 0} 100%{background-position:200% 0} }

    .pulse-dot  { animation: pulse-dot 2s ease-in-out infinite; }
    .scroll-line{ animation: scroll-ln 2s ease-in-out infinite; }
    .wa-btn     { animation: wa-pulse 2.5s ease-in-out infinite; transition: transform .25s var(--ease); }
    .wa-btn:hover{ animation: none; transform: scale(1.12); box-shadow: 0 8px 32px rgba(37,211,102,.55); }

    /* Reveal */
    .reveal       { opacity:0; transform:translateY(36px);  transition: opacity .85s var(--ease), transform .85s var(--ease); }
    .reveal-left  { opacity:0; transform:translateX(-44px); transition: opacity .85s var(--ease), transform .85s var(--ease); }
    .reveal-right { opacity:0; transform:translateX(44px);  transition: opacity .85s var(--ease), transform .85s var(--ease); }
    .reveal.visible, .reveal-left.visible, .reveal-right.visible { opacity:1; transform:none; }
    .delay-1 { transition-delay:.12s; }
    .delay-2 { transition-delay:.24s; }
    .delay-3 { transition-delay:.36s; }
    .delay-4 { transition-delay:.48s; }

    /* ================================================================
       NAVBAR
    ================================================================ */
    #navbar {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 1.5rem 2.5rem;
      transition: all .4s var(--ease);
    }
    #navbar.scrolled {
      background: rgba(20,20,18,.88);
      backdrop-filter: blur(20px) saturate(180%);
      -webkit-backdrop-filter: blur(20px) saturate(180%);
      padding: 1rem 2.5rem;
      box-shadow: 0 1px 0 rgba(255,255,255,.06), 0 8px 32px rgba(0,0,0,.4);
    }

    .nav-logo {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.5rem; font-weight: 300;
      color: var(--snow); text-decoration: none;
      letter-spacing: .02em;
      transition: opacity .2s;
    }
    .nav-logo:hover { opacity: .8; }
    .nav-logo em { color: var(--fern); font-style: italic; }

    .nav-links { display: flex; gap: 2.5rem; list-style: none; }
    .nav-links a {
      color: rgba(255,255,255,.65); text-decoration: none;
      font-size: .75rem; letter-spacing: .12em; text-transform: uppercase;
      transition: color .2s;
      position: relative;
    }
    .nav-links a::after {
      content: ''; position: absolute; bottom: -3px; left: 0; right: 0; height: 1px;
      background: var(--fern); transform: scaleX(0); transition: transform .3s var(--ease);
    }
    .nav-links a:hover { color: var(--snow); }
    .nav-links a:hover::after { transform: scaleX(1); }

    .nav-actions { display: flex; align-items: center; gap: .6rem; }

    .btn-ghost {
      display: inline-flex; align-items: center; gap: .4rem;
      color: rgba(255,255,255,.65); text-decoration: none;
      border: 1px solid rgba(255,255,255,.2);
      padding: .5rem 1.1rem; border-radius: var(--r-sm);
      font-size: .72rem; letter-spacing: .08em; text-transform: uppercase;
      transition: all .25s var(--ease);
      backdrop-filter: blur(8px);
    }
    .btn-ghost:hover {
      color: var(--snow);
      border-color: rgba(255,255,255,.5);
      background: rgba(255,255,255,.06);
    }

    .btn-primary {
      display: inline-flex; align-items: center; gap: .45rem;
      color: var(--snow); text-decoration: none;
      background: var(--sage);
      padding: .55rem 1.3rem; border-radius: var(--r-sm);
      font-size: .72rem; font-weight: 500; letter-spacing: .1em; text-transform: uppercase;
      transition: all .25s var(--ease);
      box-shadow: var(--shadow-fern);
    }
    .btn-primary:hover {
      background: var(--fern2);
      transform: translateY(-1px);
      box-shadow: 0 12px 36px rgba(107,143,94,.3);
    }

    /* Hamburger */
    #hamburger-btn {
      display: none; flex-direction: column; gap: 5px;
      background: none; border: 1px solid rgba(255,255,255,.2);
      border-radius: var(--r-sm); cursor: pointer;
      padding: .55rem .65rem;
      transition: border-color .2s;
    }
    #hamburger-btn span {
      width: 20px; height: 1.5px; background: var(--snow); display: block;
      transition: transform .3s var(--ease), opacity .3s;
    }
    #hamburger-btn:hover { border-color: rgba(255,255,255,.5); }

    /* Mobile menu */
    #mobile-menu {
      display: none; position: fixed; inset: 0; z-index: 200;
      background: rgba(10,11,10,.97);
      backdrop-filter: blur(24px) saturate(180%);
      -webkit-backdrop-filter: blur(24px) saturate(180%);
      flex-direction: column; align-items: center; justify-content: center; gap: .5rem;
    }
    #mobile-menu.open { display: flex; animation: float-in .35s var(--ease); }

    .mobile-close {
      position: absolute; top: 1.5rem; right: 1.5rem;
      background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.15);
      border-radius: 50%; width: 40px; height: 40px;
      display: flex; align-items: center; justify-content: center;
      color: var(--snow); font-size: 1.1rem; cursor: pointer;
      transition: background .2s;
    }
    .mobile-close:hover { background: rgba(255,255,255,.15); }

    .mobile-nav a {
      font-family: 'Cormorant Garamond', serif;
      color: rgba(255,255,255,.7); text-decoration: none;
      font-size: 2.6rem; font-weight: 300;
      display: block; text-align: center; padding: .4rem 2rem;
      transition: color .3s, transform .3s;
    }
    .mobile-nav a:hover { color: var(--snow); transform: translateX(8px); }

    .mobile-divider {
      width: 1px; height: 40px;
      background: linear-gradient(to bottom, transparent, rgba(255,255,255,.2), transparent);
      margin: .5rem 0;
    }

    /* ================================================================
       HERO
    ================================================================ */
    #hero {
      position: relative; height: 100svh; min-height: 620px;
      display: flex; align-items: center; overflow: hidden;
    }

    #parallax-bg {
      position: absolute; inset: -10%; z-index: 0;
    }
    #parallax-bg img {
      width: 100%; height: 100%; object-fit: cover; display: block;
    }

    .hero-overlay {
      position: absolute; inset: 0; z-index: 1;
      background:
        radial-gradient(ellipse at 30% 50%, rgba(26,46,26,.7) 0%, transparent 70%),
        linear-gradient(135deg, rgba(20,20,18,.8) 0%, rgba(20,20,18,.3) 60%, rgba(74,122,138,.25) 100%);
    }

    .hero-content {
      position: relative; z-index: 2;
      padding: 0 2.5rem;
      max-width: min(800px, 92vw);
    }

    .hero-badge {
      display: inline-flex; align-items: center; gap: .5rem;
      background: rgba(255,255,255,.07);
      border: 1px solid rgba(255,255,255,.12);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      padding: .4rem 1rem; border-radius: 100px;
      margin-bottom: 1.8rem;
    }
    .hero-badge span {
      color: var(--mist); font-size: .68rem;
      letter-spacing: .18em; text-transform: uppercase;
    }

    .hero-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2.8rem, 8vw, 5.5rem);
      font-weight: 300; color: var(--snow);
      line-height: 1.05; margin-bottom: 1.4rem;
    }
    .hero-title em { font-style: italic; color: var(--mist); }

    .hero-sub {
      color: rgba(255,255,255,.68);
      font-size: clamp(.88rem, 2vw, 1rem);
      font-weight: 300; line-height: 1.75;
      max-width: 460px; margin-bottom: 2.5rem;
    }

    .hero-ctas { display: flex; flex-wrap: wrap; gap: .9rem; }

    .btn-hero-primary {
      display: inline-flex; align-items: center; gap: .55rem;
      background: var(--sage); color: var(--snow); text-decoration: none;
      padding: .85rem 2rem; border-radius: var(--r-md);
      font-size: .78rem; font-weight: 500; letter-spacing: .1em; text-transform: uppercase;
      transition: all .3s var(--ease);
      box-shadow: 0 4px 20px rgba(107,143,94,.35), 0 1px 3px rgba(0,0,0,.3);
    }
    .btn-hero-primary:hover {
      background: var(--fern2);
      transform: translateY(-2px);
      box-shadow: 0 12px 40px rgba(107,143,94,.45), 0 2px 8px rgba(0,0,0,.3);
    }

    .btn-hero-secondary {
      display: inline-flex; align-items: center; gap: .55rem;
      border: 1px solid rgba(255,255,255,.28); color: var(--snow); text-decoration: none;
      padding: .85rem 2rem; border-radius: var(--r-md);
      font-size: .78rem; font-weight: 400; letter-spacing: .1em; text-transform: uppercase;
      transition: all .3s var(--ease);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
    }
    .btn-hero-secondary:hover {
      background: rgba(255,255,255,.08);
      border-color: rgba(255,255,255,.5);
      transform: translateY(-2px);
    }

    .hero-scroll-hint {
      position: absolute; bottom: 2.5rem; left: 50%; transform: translateX(-50%);
      display: flex; flex-direction: column; align-items: center; gap: .5rem;
      color: rgba(255,255,255,.45);
      font-size: .62rem; letter-spacing: .2em; text-transform: uppercase;
      z-index: 2;
    }

    /* Weather widget */
    #weather-widget {
      position: absolute; top: 50%; right: 2.5rem;
      transform: translateY(-50%); z-index: 3;
      background: rgba(18,18,16,.65);
      backdrop-filter: blur(20px) saturate(160%);
      -webkit-backdrop-filter: blur(20px) saturate(160%);
      border: 1px solid rgba(255,255,255,.1);
      border-radius: var(--r-lg);
      padding: 1.4rem 1.6rem;
      min-width: 185px;
      box-shadow: var(--shadow-md), inset 0 1px 0 rgba(255,255,255,.08);
    }
    #weather-widget .label {
      color: var(--fern); font-size: .58rem;
      letter-spacing: .22em; text-transform: uppercase; margin-bottom: .9rem;
      display: flex; align-items: center; gap: .4rem;
    }

    /* ================================================================
       SECTIONS
    ================================================================ */
    .section { padding: clamp(4rem, 8vw, 7rem) clamp(1.25rem, 4vw, 3rem); }
    .container { max-width: 1160px; margin: 0 auto; }

    .section-label {
      color: var(--fern); font-size: .62rem; font-weight: 500;
      letter-spacing: .28em; text-transform: uppercase; margin-bottom: 1rem;
      display: flex; align-items: center; gap: .5rem;
    }
    .section-label::before {
      content: ''; display: block; width: 24px; height: 1px; background: var(--fern);
    }

    .section-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2rem, 5vw, 3rem);
      font-weight: 300; color: var(--snow);
      line-height: 1.1;
    }
    .section-title em { font-style: italic; color: var(--fern); }

    /* ================================================================
       ABOUT
    ================================================================ */
    #about { background: var(--ink); }

    .about-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: clamp(2.5rem, 6vw, 5rem);
      align-items: center;
    }

    .about-img-wrap {
      position: relative;
    }
    .about-img-wrap::before {
      content: ''; position: absolute;
      inset: -1px;
      border-radius: calc(var(--r-xl) + 2px);
      background: linear-gradient(135deg, rgba(107,143,94,.3) 0%, rgba(74,122,138,.15) 100%);
      z-index: -1;
    }
    .about-img-wrap img {
      width: 100%; height: 500px; object-fit: cover;
      border-radius: var(--r-xl);
      display: block;
      box-shadow: var(--shadow-lg);
    }
    .about-accent {
      position: absolute; bottom: -1.2rem; right: -1.2rem;
      width: 160px; height: 160px;
      background: linear-gradient(135deg, var(--moss), var(--forest));
      border-radius: var(--r-lg);
      z-index: -2;
      box-shadow: var(--shadow-md);
    }
    .about-badge {
      position: absolute; top: 1.5rem; left: 1.5rem;
      background: rgba(18,18,16,.8);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid rgba(107,143,94,.3);
      border-radius: var(--r-md);
      padding: .7rem 1rem;
      box-shadow: var(--shadow-md), var(--shadow-fern);
    }
    .about-badge .rating { font-family: 'Cormorant Garamond', serif; font-size: 1.6rem; color: var(--snow); line-height: 1; }
    .about-badge .stars  { color: var(--fern); font-size: .7rem; margin: .1rem 0; }
    .about-badge .label  { color: rgba(255,255,255,.5); font-size: .6rem; letter-spacing: .1em; text-transform: uppercase; }

    .about-text p {
      color: rgba(255,255,255,.58);
      line-height: 1.85; font-size: .93rem;
      margin-bottom: 1.1rem;
    }

    .stats-row {
      display: flex; gap: 2.5rem;
      margin-top: 2.5rem; padding-top: 2rem;
      border-top: 1px solid rgba(255,255,255,.07);
    }
    .stat-val {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2.4rem; font-weight: 300;
      color: var(--fern); line-height: 1;
    }
    .stat-lbl {
      color: rgba(255,255,255,.38);
      font-size: .65rem; letter-spacing: .1em;
      text-transform: uppercase; margin-top: .3rem;
    }

    /* ================================================================
       SERVICES
    ================================================================ */
    #services { background: var(--inkbase); }

    .services-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
      margin-top: 3.5rem;
    }

    .service-card {
      background: rgba(255,255,255,.03);
      border: 1px solid rgba(255,255,255,.07);
      border-radius: var(--r-xl);
      overflow: hidden;
      transition: transform .4s var(--ease), box-shadow .4s var(--ease), border-color .4s;
      box-shadow: 0 4px 24px rgba(0,0,0,.3), 0 1px 4px rgba(0,0,0,.2);
    }
    .service-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 24px 64px rgba(0,0,0,.45), 0 8px 20px rgba(0,0,0,.25), var(--shadow-glow);
      border-color: rgba(107,143,94,.2);
    }

    .card-img-wrap { overflow: hidden; }
    .card-img-wrap img {
      width: 100%; height: 240px; object-fit: cover; display: block;
      filter: brightness(.8) saturate(.9);
      transition: transform .7s var(--ease), filter .5s;
    }
    .service-card:hover .card-img-wrap img {
      transform: scale(1.07);
      filter: brightness(.95) saturate(1.05);
    }

    .card-body { padding: 1.8rem 1.8rem 2rem; }

    .card-icon {
      width: 38px; height: 38px;
      border-radius: var(--r-sm);
      display: flex; align-items: center; justify-content: center;
      font-size: 1rem; margin-bottom: 1.1rem;
    }
    .card-icon-fern    { background: rgba(107,143,94,.15); border: 1px solid rgba(107,143,94,.25); }
    .card-icon-glacier { background: rgba(74,122,138,.15); border: 1px solid rgba(74,122,138,.25); }

    .card-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.3rem; font-weight: 400;
      color: var(--snow); margin-bottom: .6rem;
    }

    .card-desc {
      color: rgba(255,255,255,.48);
      font-size: .82rem; line-height: 1.72;
      margin-bottom: 1.1rem;
    }

    .card-features { list-style: none; margin-bottom: 1.3rem; display: flex; flex-direction: column; gap: .38rem; }
    .card-features li {
      color: rgba(255,255,255,.42);
      font-size: .76rem;
      display: flex; align-items: center; gap: .5rem;
    }
    .card-features li .check { color: var(--fern); flex-shrink: 0; }
    .card-features li .check-blue { color: var(--ice); flex-shrink: 0; }

    .card-cta {
      color: var(--fern); font-size: .7rem;
      letter-spacing: .15em; text-transform: uppercase;
      text-decoration: none; display: inline-flex; align-items: center; gap: .4rem;
      transition: gap .3s var(--ease), color .2s;
    }
    .card-cta.blue { color: var(--ice); }
    .card-cta:hover { gap: .7rem; color: var(--fern2); }
    .card-cta.blue:hover { color: var(--mist); }

    .badge-tag {
      position: absolute; top: 1rem; right: 1rem; z-index: 2;
      background: var(--glacier); color: var(--snow);
      font-size: .58rem; letter-spacing: .15em;
      text-transform: uppercase; padding: .3rem .75rem;
      border-radius: 100px; font-weight: 500;
      box-shadow: var(--shadow-sm);
    }

    /* ================================================================
       GALLERY
    ================================================================ */
    #gallery { background: var(--ink); }

    .gallery-grid {
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      grid-template-rows: 260px 260px;
      gap: 8px;
      margin-top: 3rem;
    }
    .g1 { grid-column: 1/6;  grid-row: 1/2; }
    .g2 { grid-column: 6/9;  grid-row: 1/2; }
    .g3 { grid-column: 9/13; grid-row: 1/3; }
    .g4 { grid-column: 1/4;  grid-row: 2/3; }
    .g5 { grid-column: 4/6;  grid-row: 2/3; }
    .g6 { grid-column: 6/9;  grid-row: 2/3; }

    .g-item {
      overflow: hidden;
      border-radius: var(--r-md);
      box-shadow: var(--shadow-md);
      position: relative;
    }
    .g-item::after {
      content: ''; position: absolute; inset: 0;
      background: linear-gradient(to bottom, transparent 50%, rgba(0,0,0,.4));
      opacity: 0; transition: opacity .4s;
      pointer-events: none;
    }
    .g-item:hover::after { opacity: 1; }
    .g-item img {
      width: 100%; height: 100%; object-fit: cover; display: block;
      filter: brightness(.82) saturate(.88);
      transition: transform .75s var(--ease), filter .45s;
    }
    .g-item:hover img { transform: scale(1.07); filter: brightness(.95) saturate(1.05); }

    /* ================================================================
       TESTIMONIALS
    ================================================================ */
    #testimonials { background: var(--inkdeep); }

    .testimonials-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
      margin-top: 3.5rem;
    }

    .testi-card {
      background: rgba(255,255,255,.03);
      border: 1px solid rgba(255,255,255,.07);
      border-radius: var(--r-xl);
      padding: 2rem;
      transition: transform .35s var(--ease), box-shadow .35s var(--ease), border-color .35s;
      box-shadow: 0 4px 20px rgba(0,0,0,.3);
    }
    .testi-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 16px 48px rgba(0,0,0,.4), 0 4px 12px rgba(0,0,0,.2);
      border-color: rgba(107,143,94,.18);
    }

    .testi-stars { color: var(--fern); font-size: .78rem; letter-spacing: .1em; margin-bottom: 1.1rem; }

    .testi-quote {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.05rem; font-weight: 300; font-style: italic;
      color: var(--cloud); line-height: 1.72;
      margin-bottom: 1.5rem;
    }

    .testi-author { display: flex; align-items: center; gap: .8rem; }
