---
import { getCollection } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

// El sitio se sirve en modo servidor, así que getStaticPaths no limita las
// rutas: hay que buscar el artículo en cada pedido y responder 404 si no
// existe. Sin esto, cualquier /blog/loquesea devolvía 200 con la página
// vacía, y Google lo trata como soft 404.
const { slug } = Astro.params;

const posts = await getCollection('blog');
const post = posts.find((p) => p.slug === slug);

if (!post) {
  return new Response(null, { status: 404 });
}

const { Content } = await post.render();
---

<BlogPost {...post.data}>
  <Content />
</BlogPost>
