<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Hostal El Monchito — Puerto Cisnes, Patagonia Chilena</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />

  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            forest:  '#1a2e1a',
            moss:    '#2d4a2d',
            sage:    '#4a6741',
            fern:    '#6b8f5e',
            glacier: '#4a7a8a',
            ice:     '#7fb3c0',
            mist:    '#b8d4db',
            cloud:   '#e8e4df',
            snow:    '#faf8f5',
            ink:     '#1a1a18',
            inkdeep: '#0f1010',
            inkbase: '#141412',
            wa:      '#25D366',
          },
          fontFamily: {
            serif: ['"Cormorant Garamond"', 'serif'],
            sans:  ['"DM Sans"', 'sans-serif'],
          },
        }
      }
    }
  </script>

  <style>
    /* ================================================================
       BASE OSCURA — garantiza tema independiente del CDN
    ================================================================ */
    *, *::before, *::after { box-sizing: border-box; }

    html {
      background-color: #1a1a18;
      color: #e8e4df;
      font-family: 'DM Sans', sans-serif;
    }
    body {
      background-color: #1a1a18;
      color: #e8e4df;
      font-family: 'DM Sans', sans-serif;
      overflow-x: hidden;
      margin: 0;
    }

    /* ================================================================
       COLORES PERSONALIZADOS (necesario para CDN play mode)
    ================================================================ */
    .c-bg-ink     { background-color: #1a1a18; }
    .c-bg-inkbase { background-color: #141412; }
    .c-bg-inkdeep { background-color: #0f1010; }
    .c-bg-footer  { background-color: #0a0b0a; }
    .c-bg-sage    { background-color: #4a6741; }
    .c-bg-moss    { background-color: #2d4a2d; }
    .c-bg-glacier { background-color: #4a7a8a; }
    .c-bg-wa      { background-color: #25D366; }
    .c-bg-fern-card { background-color: rgba(107,143,94,0.15); }
    .c-bg-glacier-card { background-color: rgba(74,122,138,0.15); }

    .c-text-snow  { color: #faf8f5; }
    .c-text-cloud { color: #e8e4df; }
    .c-text-fern  { color: #6b8f5e; }
    .c-text-mist  { color: #b8d4db; }
    .c-text-ice   { color: #7fb3c0; }
    .c-text-white70  { color: rgba(255,255,255,0.70); }
    .c-text-white60  { color: rgba(255,255,255,0.60); }
    .c-text-white50  { color: rgba(255,255,255,0.50); }
    .c-text-white45  { color: rgba(255,255,255,0.45); }
    .c-text-white40  { color: rgba(255,255,255,0.40); }
    .c-text-white25  { color: rgba(255,255,255,0.25); }

    .c-border-fern     { border-color: rgba(107,143,94,0.30); }
    .c-border-glacier  { border-color: rgba(74,122,138,0.30); }
    .c-border-white6   { border-color: rgba(255,255,255,0.06); }
    .c-border-white8   { border-color: rgba(255,255,255,0.08); }
    .c-border-white10  { border-color: rgba(255,255,255,0.10); }
    .c-border-white15  { border-color: rgba(255,255,255,0.15); }
    .c-border-white25  { border-color: rgba(255,255,255,0.25); }

    /* hovers */
    .c-hover-sage:hover    { background-color: #6b8f5e; }
    .c-hover-snow:hover    { color: #faf8f5; }
    .c-hover-fern:hover    { color: #6b8f5e; }
    .c-hover-bfern:hover   { border-color: #6b8f5e; }
    .c-hover-bgfern10:hover { background-color: rgba(107,143,94,0.10); }
    .c-hover-bwhite60:hover { border-color: rgba(255,255,255,0.60); }
    .c-hover-bgwhite5:hover { background-color: rgba(255,255,255,0.05); }

    /* ================================================================
       TIPOGRAFÍA
    ================================================================ */
    .font-serif { font-family: 'Cormorant Garamond', serif; }
    .font-sans  { font-family: 'DM Sans', sans-serif; }

    /* ================================================================
       SCROLLBAR
    ================================================================ */
    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-track { background: #1a1a18; }
    ::-webkit-scrollbar-thumb { background: #4a6741; border-radius: 2px; }

    /* ================================================================
       ANIMACIONES REVEAL
    ================================================================ */
    .reveal        { opacity:0; transform:translateY(40px);  transition: opacity .9s cubic-bezier(.16,1,.3,1), transform .9s cubic-bezier(.16,1,.3,1); }
    .reveal-left   { opacity:0; transform:translateX(-50px); transition: opacity .9s cubic-bezier(.16,1,.3,1), transform .9s cubic-bezier(.16,1,.3,1); }
    .reveal-right  { opacity:0; transform:translateX(50px);  transition: opacity .9s cubic-bezier(.16,1,.3,1), transform .9s cubic-bezier(.16,1,.3,1); }
    .reveal.visible, .reveal-left.visible, .reveal-right.visible { opacity:1; transform:none; }
    .delay-1 { transition-delay:.15s; }
    .delay-2 { transition-delay:.30s; }
    .delay-3 { transition-delay:.45s; }

    /* ================================================================
       KEYFRAMES
    ================================================================ */
    @keyframes pulse-dot  { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.5;transform:scale(.8)} }
    .pulse-dot { animation: pulse-dot 2s infinite; }

    @keyframes scroll-ln  { 0%,100%{transform:scaleY(1);opacity:1} 50%{transform:scaleY(.5);opacity:.5} }
    .scroll-line { animation: scroll-ln 2s ease-in-out infinite; }

    @keyframes wa-pulse {
      0%,100% { box-shadow: 0 4px 20px rgba(37,211,102,.4); }
      50%      { box-shadow: 0 4px 30px rgba(37,211,102,.7), 0 0 0 8px rgba(37,211,102,.1); }
    }
    .wa-btn { animation: wa-pulse 2.5s ease-in-out infinite; transition: transform .2s; }
    .wa-btn:hover { animation: none; transform: scale(1.1); }

    /* ================================================================
       NAVBAR
    ================================================================ */
    #navbar {
      position: fixed; top:0; left:0; right:0; z-index:50;
      display: flex; align-items: center; justify-content: space-between;
      padding: 1.5rem 3rem;
      background: transparent;
      transition: background .3s, padding .3s, backdrop-filter .3s, border-color .3s;
    }
    #navbar.scrolled {
      background: rgba(26,26,24,0.92);
      backdrop-filter: blur(12px);
      padding: 1rem 3rem;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    @media(max-width:768px) {
      #navbar { padding: 1.2rem 1.5rem; }
      #navbar.scrolled { padding: 1rem 1.5rem; }
    }

    /* ================================================================
       HERO
    ================================================================ */
    #hero {
      position: relative;
      height: 100vh; min-height: 700px;
      display: flex; align-items: center;
      overflow: hidden;
    }
    #parallax-bg {
      position: absolute; inset: 0;
      transform: scale(1.1);
    }
    #parallax-bg img {
      width:100%; height:100%; object-fit:cover; display:block;
    }
    .hero-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(135deg, rgba(26,46,26,.75) 0%, rgba(26,26,24,.5) 50%, rgba(74,122,138,.3) 100%);
    }
    .hero-badge {
      display: inline-flex; align-items: center; gap: .5rem;
      background: rgba(255,255,255,.08);
      border: 1px solid rgba(255,255,255,.15);
      backdrop-filter: blur(8px);
      padding: .4rem 1rem; border-radius: 100px;
      margin-bottom: 2rem;
    }
    .hero-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(3rem,7vw,5.5rem);
      font-weight: 300;
      color: #faf8f5;
      line-height: 1.05;
      margin-bottom: 1.5rem;
    }
    .hero-scroll {
      position: absolute; bottom: 2.5rem; left: 50%; transform: translateX(-50%);
      display: flex; flex-direction: column; align-items: center; gap: .5rem;
      color: rgba(255,255,255,.5);
      font-size: .65rem; letter-spacing: .2em; text-transform: uppercase;
    }

    /* ================================================================
       WEATHER WIDGET
    ================================================================ */
    #weather-widget {
      position: absolute; top:50%; right:3rem; transform:translateY(-50%);
      background: rgba(26,26,24,.6);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(255,255,255,.1);
      border-radius: 8px; padding: 1.2rem 1.5rem; min-width:180px; z-index:3;
    }
    @media(max-width:1024px){ #weather-widget { display:none; } }

    /* ================================================================
       SECCIONES
    ================================================================ */
    section { padding: 7rem 3rem; }
    .container { max-width: 1200px; margin: 0 auto; }
    @media(max-width:768px){ section { padding: 5rem 1.5rem; } }

    /* About accent */
    .img-accent { position: relative; z-index: 0; }
    .img-accent::after {
      content:''; position:absolute; bottom:-1.5rem; right:-1.5rem;
      width:180px; height:180px; background:#2d4a2d; border-radius:4px; z-index:-1;
    }

    /* ================================================================
       GALLERY GRID ASIMÉTRICO
    ================================================================ */
    .gallery-grid {
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      grid-template-rows: 280px 280px;
      gap: 6px;
    }
    .g1 { grid-column:1/6;  grid-row:1/2; }
    .g2 { grid-column:6/9;  grid-row:1/2; }
    .g3 { grid-column:9/13; grid-row:1/3; }
    .g4 { grid-column:1/4;  grid-row:2/3; }
    .g5 { grid-column:4/6;  grid-row:2/3; }
    .g6 { grid-column:6/9;  grid-row:2/3; }
    @media(max-width:768px){
      .gallery-grid { grid-template-columns:1fr 1fr; grid-template-rows:auto; }
      .g1,.g2,.g3,.g4,.g5,.g6 { grid-column:auto; grid-row:auto; height:200px; }
    }
    .g-item { overflow:hidden; border-radius:2px; }
    .g-item img {
      width:100%; height:100%; object-fit:cover; display:block;
      filter: brightness(.8) saturate(.9);
      transition: transform .7s cubic-bezier(.16,1,.3,1), filter .4s;
    }
    .g-item:hover img { transform:scale(1.07); filter:brightness(1) saturate(1.1); }

    /* ================================================================
       SERVICE CARDS
    ================================================================ */
    .service-card .card-img img {
      width:100%; height:260px; object-fit:cover; display:block;
      filter: brightness(.85);
      transition: transform .7s cubic-bezier(.16,1,.3,1), filter .4s;
    }
    .service-card:hover .card-img img { transform:scale(1.06); filter:brightness(1); }
    .card-arrow { transition: letter-spacing .3s; }
    .service-card:hover .card-arrow { letter-spacing:.18em; }

    /* ================================================================
       FOOTER
    ================================================================ */
    footer { background-color: #0a0b0a; border-top: 1px solid rgba(255,255,255,.06); }
    .footer-grid {
      display: grid;
      grid-template-columns: 1.5fr 1fr 1fr 1fr;
      gap: 3rem;
      padding: 5rem 3rem;
      max-width: 1200px; margin: 0 auto;
    }
    @media(max-width:1024px){ .footer-grid { grid-template-columns: 1fr 1fr; } }
    @media(max-width:768px) { .footer-grid { grid-template-columns: 1fr; padding: 3rem 1.5rem; } }
    .footer-bottom {
      max-width:1200px; margin:0 auto;
      padding: 1.5rem 3rem;
      border-top: 1px solid rgba(255,255,255,.05);
      display:flex; flex-wrap:wrap; align-items:center; justify-content:space-between; gap:1rem;
    }
    @media(max-width:768px){ .footer-bottom { padding: 1.2rem 1.5rem; } }

    /* ================================================================
       SOCIAL SIDEBAR & WHATSAPP
    ================================================================ */
    #social-sidebar {
      position:fixed; left:1.5rem; top:50%; transform:translateY(-50%);
      z-index:99; display:flex; flex-direction:column; align-items:center; gap:.6rem;
    }
    @media(max-width:1024px){ #social-sidebar { display:none; } }

    .sidebar-icon {
      width:32px; height:32px; border-radius:4px; display:flex;
      align-items:center; justify-content:center;
      border: 1px solid rgba(255,255,255,.15);
      background: rgba(26,26,24,.6); backdrop-filter:blur(6px);
      color: rgba(255,255,255,.5); text-decoration:none;
      transition: border-color .3s, color .3s, background .3s;
    }
    .sidebar-icon:hover { border-color:#6b8f5e; color:#6b8f5e; background:rgba(107,143,94,.1); }
    .sidebar-line      { width:1px; height:50px; background:linear-gradient(to bottom, transparent, rgba(255,255,255,.2)); }
    .sidebar-line-b    { width:1px; height:50px; background:linear-gradient(to top,   transparent, rgba(255,255,255,.2)); }

    /* Mobile menu */
    #mobile-menu {
      display:none; position:fixed; inset:0; z-index:200;
      background:rgba(10,11,10,.97); backdrop-filter:blur(20px);
      flex-direction:column; align-items:center; justify-content:center; gap:2rem;
    }
    #mobile-menu.open { display:flex; }
  </style>
</head>

<body>

