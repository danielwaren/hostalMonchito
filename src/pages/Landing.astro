<!-- ===== JS ===== -->
<script>
  // Navbar scroll
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    navbar.classList.toggle('scrolled', window.scrollY > 60);
  });

  // Hamburger — mostrar/ocultar correctamente en mobile
  const hamburgerBtn   = document.getElementById('hamburger-btn');
  const mobileMenu     = document.getElementById('mobile-menu');
  const mobileCloseBtn = document.getElementById('mobile-close-btn');

  // Mostrar hamburger solo en mobile
  function checkMobile() {
    hamburgerBtn.style.display = window.innerWidth < 768 ? 'flex' : 'none';
  }
  checkMobile();
  window.addEventListener('resize', checkMobile);

  hamburgerBtn.addEventListener('click',   () => mobileMenu.classList.add('open'));
  mobileCloseBtn.addEventListener('click', () => mobileMenu.classList.remove('open'));
  mobileMenu.querySelectorAll('a').forEach(a => a.addEventListener('click', () => mobileMenu.classList.remove('open')));

  // Parallax hero
  const parallaxBg = document.getElementById('parallax-bg');
  window.addEventListener('scroll', () => {
    if (window.scrollY < window.innerHeight) {
      parallaxBg.style.transform = `scale(1.1) translateY(${window.scrollY * 0.3}px)`;
    }
  });

  // Scroll reveal
  const revealEls = document.querySelectorAll('.reveal, .reveal-left, .reveal-right');
  const observer  = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); } });
  }, { threshold: 0.12, rootMargin: '0px 0px -60px 0px' });
  revealEls.forEach(el => observer.observe(el));

  // Weather
  async function fetchWeather() {
    try {
      const res  = await fetch('https://api.open-meteo.com/v1/forecast?latitude=-44.725&longitude=-72.755&current=temperature_2m,relative_humidity_2m,wind_speed_10m,weather_code&wind_speed_unit=kmh&timezone=America%2FSantiago');
      const data = await res.json();
      const c    = data.current;
      const wmo  = code => {
        if (code===0) return {icon:'☀️',desc:'Despejado'};
        if ([1,2,3].includes(code)) return {icon:'⛅',desc:'Parcialmente nublado'};
        if ([45,48].includes(code)) return {icon:'🌫️',desc:'Neblina'};
        if ([51,53,55,61,63].includes(code)) return {icon:'🌧️',desc:'Lluvia ligera'};
        if ([65,66,67,80,81,82].includes(code)) return {icon:'🌧️',desc:'Lluvia'};
        if ([71,73,75,77,85,86].includes(code)) return {icon:'❄️',desc:'Nieve'};
        if ([95,96,99].includes(code)) return {icon:'⛈️',desc:'Tormenta'};
        return {icon:'🌡️',desc:'Variable'};
      };
      const {icon, desc} = wmo(c.weather_code);
      document.getElementById('weather-main-content').innerHTML = `
        <div style="display:flex;align-items:center;gap:.8rem;margin-bottom:.5rem">
          <span style="font-size:2.2rem">${icon}</span>
          <span style="font-family:'Cormorant Garamond',serif;font-size:2rem;color:#faf8f5;line-height:1">${Math.round(c.temperature_2m)}°C</span>
        </div>
        <div style="font-size:.75rem;color:rgba(255,255,255,.6);margin-bottom:.5rem;text-transform:capitalize">${desc}</div>
        <div style="display:flex;gap:1rem">
          <div style="font-size:.65rem;color:rgba(255,255,255,.5)"><strong style="color:#b8d4db;display:block">${c.relative_humidity_2m}%</strong>Humedad</div>
          <div style="font-size:.65rem;color:rgba(255,255,255,.5)"><strong style="color:#b8d4db;display:block">${Math.round(c.wind_speed_10m)} km/h</strong>Viento</div>
        </div>`;
    } catch(e) {
      document.getElementById('weather-main-content').innerHTML = '<p style="font-size:.75rem;color:rgba(255,255,255,.5)">Clima no disponible</p>';
    }
  }
  fetchWeather();
</script>
</body>
