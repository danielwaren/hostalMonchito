---
export const prerender = false;

const muestras = [
  {
    n: "01",
    slug: "editorial",
    nombre: "Editorial Patagónico",
    fuentes: "Fraunces + Work Sans",
    idea: "Como una revista de viajes impresa. Titular enorme en serif, mucho aire, filetes finos, fotos a sangre. El scroll revela el título línea por línea.",
    fuerte: "El más legible y el que mejor le sienta al blog.",
  },
  {
    n: "02",
    slug: "cartografico",
    nombre: "Cartográfico",
    fuentes: "Archivo + IBM Plex Mono",
    idea: "Cartas náuticas y mapas topográficos del fiordo. Curvas de nivel dibujadas en canvas que se recorren con el scroll, coordenadas reales, retícula y monoespaciada.",
    fuerte: "El más propio de Puerto Cisnes: imposible confundirlo con una plantilla.",
  },
  {
    n: "03",
    slug: "cinematico",
    nombre: "Cinemático",
    fuentes: "Bodoni Moda + Jost",
    idea: "Las fotos mandan. Capítulos a pantalla completa encadenados con ScrollTrigger, tipografía dramática sobre imagen, movimiento de cámara.",
    fuerte: "El de mayor impacto en pantalla grande.",
  },
];
---
<!doctype html>
<html lang="es-CL">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Tres direcciones de diseño — Hostal Monchito</title>
  <style>
    :root { color-scheme: dark; }
    * { margin:0; padding:0; box-sizing:border-box; }
    body {
      background:#0d1210; color:#a9b5b0;
      font-family:ui-sans-serif, system-ui, -apple-system, "Segoe UI", sans-serif;
      font-size:16px; line-height:1.7; -webkit-font-smoothing:antialiased;
      padding:clamp(40px,9vh,90px) clamp(20px,5vw,40px) 80px;
    }
    .wrap { max-width:820px; margin:0 auto; }
    .eyebrow { font-size:11px; letter-spacing:.26em; text-transform:uppercase; color:#c8a97a; margin-bottom:16px; }
    h1 { font-family:Georgia, serif; font-weight:400; font-size:clamp(28px,5.2vw,40px);
         color:#eef2ef; line-height:1.14; margin-bottom:14px; letter-spacing:-.01em; }
    .intro { max-width:60ch; margin-bottom:12px; }
    .nota { font-size:14px; color:#77837e; max-width:60ch; margin-bottom:44px; }
    .lista { display:flex; flex-direction:column; gap:2px; }
    a.card {
      display:block; text-decoration:none; background:#131a18; border:1px solid #223029;
      padding:26px 26px 28px; transition:border-color .3s, background .3s, transform .3s;
    }
    a.card:hover { border-color:#6fbf9f; background:#16201d; transform:translateX(5px); }
    a.card:focus-visible { outline:2px solid #c8a97a; outline-offset:3px; }
    .top { display:flex; align-items:baseline; gap:14px; margin-bottom:11px; flex-wrap:wrap; }
    .num { font-family:ui-monospace, monospace; font-size:12px; color:#c8a97a; }
    .nombre { font-family:Georgia, serif; font-size:24px; color:#eef2ef; flex:1; }
    .fuentes { font-family:ui-monospace, monospace; font-size:11px; color:#6d7873; }
    .idea { font-size:15px; margin-bottom:9px; }
    .fuerte { font-size:14px; color:#8fc9ae; }
    .ver { display:inline-block; margin-top:16px; font-size:12px; letter-spacing:.14em;
           text-transform:uppercase; color:#c8a97a; }
    footer { margin-top:44px; padding-top:24px; border-top:1px solid #223029;
             font-size:13.5px; color:#6d7873; }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="eyebrow">Rediseño · Etapa 1</div>
    <h1>Tres direcciones para el sitio</h1>
    <p class="intro">
      Cada una está construida con las fuentes definitivas, tus fotos y GSAP funcionando,
      para que puedas juzgar el movimiento y no sólo una imagen fija.
    </p>
    <p class="nota">
      Probá el scroll y el botón de claro/oscuro en cada una. Son maquetas de la portada:
      cuando elijas, llevo esa dirección a la home completa y después al resto del sitio.
    </p>

    <div class="lista">
      {muestras.map((m) => (
        <a class="card" href={`/muestra/${m.slug}`}>
          <div class="top">
            <span class="num">{m.n}</span>
            <span class="nombre">{m.nombre}</span>
            <span class="fuentes">{m.fuentes}</span>
          </div>
          <p class="idea">{m.idea}</p>
          <p class="fuerte">{m.fuerte}</p>
          <span class="ver">Ver muestra →</span>
        </a>
      ))}
    </div>

    <footer>
      Estas páginas son temporales y llevan noindex: no las va a indexar Google.
      Las elimino cuando elijas la dirección.
    </footer>
  </div>
</body>
</html>
