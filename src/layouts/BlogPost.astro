  <!-- ══════════════════ SCRIPTS ══════════════════ -->
  <script define:vars={{ pageUrl, title, description }}>
    /* ── Reading progress ── */
    const fill = document.getElementById('progress-fill');
    const pct  = document.getElementById('progress-pct');

    function updateProgress() {
      const el      = document.documentElement;
      const scrolled = el.scrollTop;
      const total    = el.scrollHeight - el.clientHeight;
      const p        = total > 0 ? Math.round((scrolled / total) * 100) : 0;
      if (fill) fill.style.width = p + '%';
      if (pct)  {
        pct.textContent = p + '%';
        pct.style.opacity = (p > 5 && p < 98) ? '1' : '0';
      }
    }
    window.addEventListener('scroll', updateProgress, { passive: true });
    updateProgress();

    /* ── Auto reading time ── */
    const article = document.querySelector('.article-body');
    const rtEl    = document.getElementById('reading-time');
    if (article && rtEl && !rtEl.textContent.trim().replace('min de lectura','').trim()) {
      const words = article.innerText.trim().split(/\s+/).length;
      const mins  = Math.max(1, Math.round(words / 220));
      rtEl.textContent = mins + ' min de lectura';
    }

    /* ── TOC builder ── */
    const headings = article
      ? Array.from(article.querySelectorAll('h2, h3'))
      : [];
    const tocList  = document.getElementById('toc-list');
    const tocEmpty = document.getElementById('toc-empty');

    if (headings.length > 0 && tocList) {
      tocEmpty && (tocEmpty.style.display = 'none');
      headings.forEach((h, i) => {
        if (!h.id) h.id = 'section-' + i;
        const li = document.createElement('li');
        li.className = 'toc-item depth-' + (h.tagName === 'H2' ? '2' : '3');
        li.dataset.id = h.id;
        const a = document.createElement('a');
        a.href = '#' + h.id;
        a.textContent = h.textContent;
        li.appendChild(a);
        tocList.appendChild(li);
      });
    } else if (tocEmpty) {
      tocEmpty.style.display = 'block';
    }

    /* ── TOC active section highlight ── */
    const tocItems = Array.from(document.querySelectorAll('.toc-item'));
    const io = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          tocItems.forEach(li => li.classList.remove('active'));
          const match = tocItems.find(li => li.dataset.id === entry.target.id);
          if (match) match.classList.add('active');
        }
      });
    }, { rootMargin: '-20% 0px -70% 0px' });

    headings.forEach(h => io.observe(h));

    /* ── Scroll reveal ── */
    const revealEls = article
      ? Array.from(article.querySelectorAll('p, h2, h3, blockquote, ul, ol, img'))
      : [];

    revealEls.forEach(el => el.classList.add('reveal'));

    const revealIO = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          revealIO.unobserve(e.target);
        }
      });
    }, { threshold: 0.08, rootMargin: '0px 0px -30px 0px' });

    revealEls.forEach(el => revealIO.observe(el));

    /* ── Share buttons ── */
    const encodedUrl   = encodeURIComponent(pageUrl);
    const encodedTitle = encodeURIComponent(title);
    const encodedDesc  = encodeURIComponent(description || '');

    const wa = document.getElementById('share-whatsapp');
    if (wa) wa.href = `https://wa.me/?text=${encodedTitle}%20${encodedUrl}`;

    const xBtn = document.getElementById('share-x');
    if (xBtn) xBtn.href = `https://x.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`;

    const ig = document.getElementById('share-instagram');
    if (ig) {
      ig.href = '#';
      ig.addEventListener('click', e => {
        e.preventDefault();
        if (navigator.share) {
          navigator.share({ title, url: pageUrl }).catch(() => {});
        } else {
          navigator.clipboard.writeText(pageUrl).then(() => {
            ig.classList.add('copied');
            const prev = ig.lastChild;
            if (prev) prev.textContent = '¡Enlace copiado!';
            setTimeout(() => {
              ig.classList.remove('copied');
              if (prev) prev.textContent = 'Instagram';
            }, 2000);
          });
        }
      });
    }

    const copyBtn = document.getElementById('share-copy');
    if (copyBtn) {
      copyBtn.addEventListener('click', () => {
        navigator.clipboard.writeText(pageUrl).then(() => {
          copyBtn.classList.add('copied');
          const last = copyBtn.lastChild;
          if (last) last.textContent = '¡Copiado!';
          setTimeout(() => {
            copyBtn.classList.remove('copied');
            if (last) last.textContent = 'Copiar enlace';
          }, 2000);
        });
      });
    }
  </script>

