---
import BaseHead from '../components/landing/BaseHead.astro';
import NavBar from '../components/landing/Navbar.astro';

const {
  title,
  description,
  pubDate,
  image,
  author        = 'Puerto Cisnes',
  category      = 'Patagonia',
  tags          = [],
  readingTime   = '',
} = Astro.props.frontmatter ?? Astro.props;

const pageUrl   = Astro.url.href;
const siteUrl   = Astro.site ?? 'https://puertocisnes.cl';
const siteName  = 'Puerto Cisnes';

const formattedDate = pubDate
  ? new Date(pubDate).toLocaleDateString('es-CL', { year: 'numeric', month: 'long', day: 'numeric' })
  : '';
---

<html lang="es">
<head>
  <BaseHead
    title={title}
    description={description}
    image={image}
    pubDate={pubDate}
    author={author}
    tags={tags}
    type="article"
  />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;1,400;1,700&family=Inter:wght@300;400;500&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

  <style is:global>
  /* ─── TOKENS ─── */
  :root {
    --bg:          #080c0a;
    --bg-2:        #0c1210;
    --surface:     #111916;
    --surface-2:   #162019;
    --border:      rgba(100,200,140,0.10);
    --border-2:    rgba(100,200,140,0.18);
    --accent:      #5dcea0;
    --accent-dim:  rgba(93,206,160,0.12);
    --accent-glow: rgba(93,206,160,0.06);
    --gold:        #c9a040;
    --text:        #ccd9cc;
    --text-2:      #7a9a7a;
    --text-3:      #3d5c3d;
    --white:       #eaf3ea;
    --serif:       'Playfair Display', Georgia, serif;
    --sans:        'Inter', system-ui, sans-serif;
    --mono:        'JetBrains Mono', monospace;
    --nav-h:       58px;
    --r:           5px;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; scroll-padding-top: calc(var(--nav-h) + 2rem); }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--sans);
    font-weight: 300;
    -webkit-font-smoothing: antialiased;
    min-height: 100vh;
  }

  /* ─── READING PROGRESS ─── */
  #progress-track {
    position: fixed;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: rgba(93,206,160,0.08);
    z-index: 300;
  }
  #progress-fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, #3a9d6e, var(--accent), var(--gold));
    transition: width 0.1s linear;
    box-shadow: 0 0 10px rgba(93,206,160,0.4);
  }
  #progress-pct {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: 300;
    font-family: var(--mono);
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    color: var(--accent);
    background: var(--surface);
    border: 1px solid var(--border-2);
    padding: 0.3rem 0.6rem;
    border-radius: 100px;
    opacity: 0;
    transition: opacity 0.3s;
  }

  /* ─── HERO ─── */
  .hero {
    position: relative;
    width: 100%;
    height: calc(100svh - var(--nav-h) - 2px);
    margin-top: calc(var(--nav-h) + 2px);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    overflow: hidden;
    background-size: cover;
    background-position: center center;
    background-repeat: no-repeat;
    background-color: var(--surface);
  }

  /* tint layers */
  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(
        to bottom,
        rgba(8,12,10,0.30) 0%,
        rgba(8,12,10,0.10) 20%,
        transparent       45%,
        rgba(8,12,10,0.70) 75%,
        var(--bg)          100%
      );
  }

  /* subtle green cast at top to blend nav */
  .hero-overlay::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: var(--nav-h);
    background: linear-gradient(to bottom, rgba(8,12,10,0.55), transparent);
    z-index: 2;
  }

  .hero-content {
    position: relative;
    z-index: 5;
    padding: 2rem clamp(1.5rem, 6vw, 5rem) clamp(3rem, 6vw, 5rem);
    max-width: 860px;
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--mono);
    font-size: 0.58rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.5rem;
    opacity: 0;
    animation: up 0.7s 0.1s forwards;
  }

  .hero-eyebrow::before {
    content: '';
    display: block;
    width: 32px; height: 1px;
    background: var(--accent);
    flex-shrink: 0;
  }

  .hero-title {
    font-family: var(--serif);
    font-size: clamp(1.9rem, 4.5vw, 3.8rem);
    font-weight: 700;
    line-height: 1.0;
    color: var(--white);
    letter-spacing: -0.02em;
    margin-bottom: 1.75rem;
    opacity: 0;
    animation: up 0.8s 0.22s forwards;
  }

  .hero-title em {
    font-style: italic;
    color: var(--accent);
  }

  .hero-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 1.5rem;
    opacity: 0;
    animation: up 0.6s 0.38s forwards;
  }

  .hero-meta time,
  .hero-meta span {
    font-family: var(--mono);
    font-size: 0.63rem;
    letter-spacing: 0.1em;
    color: var(--text-3);
  }

  .hero-meta .dot {
    width: 3px; height: 3px;
    border-radius: 50%;
    background: var(--text-3);
    flex-shrink: 0;
  }

  .hero-desc {
    margin-top: 1.25rem;
    font-family: var(--serif);
    font-size: clamp(1rem, 1.5vw, 1.25rem);
    font-style: italic;
    line-height: 1.7;
    color: rgba(204,217,204,0.65);
    max-width: 580px;
    opacity: 0;
    animation: up 0.6s 0.5s forwards;
  }

  /* scroll indicator */
  .scroll-hint {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 6;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .scroll-line {
    width: 1px;
    height: 48px;
    background: linear-gradient(to bottom, transparent, var(--accent));
    animation: grow 2s ease infinite;
  }

  @keyframes grow {
    0%, 100% { opacity: 0; transform: scaleY(0.3) translateY(-10px); }
    50%       { opacity: 1; transform: scaleY(1) translateY(0); }
  }

  /* ─── SHARE BAR ─── */
  .share-bar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem clamp(1.5rem, 6vw, 5rem);
    border-bottom: 1px solid var(--border);
    background: var(--bg-2);
    position: sticky;
    top: var(--nav-h);
    z-index: 50;
    backdrop-filter: blur(10px);
  }

  .share-label {
    font-family: var(--mono);
    font-size: 0.55rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-3);
    margin-right: 0.25rem;
  }

  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--mono);
    font-size: 0.58rem;
    letter-spacing: 0.06em;
    color: var(--text-2);
    background: transparent;
    border: 1px solid var(--border);
    padding: 0.3rem 0.85rem;
    border-radius: var(--r);
    text-decoration: none;
    cursor: pointer;
    transition: all 0.15s;
  }

  .share-btn:hover {
    background: var(--accent-dim);
    border-color: var(--accent);
    color: var(--accent);
  }

  .share-btn svg { width: 10px; height: 10px; flex-shrink: 0; }

  .share-btn.copied { color: var(--accent); border-color: var(--accent); }

  /* ─── LAYOUT ─── */
  .page-wrap {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 clamp(1.5rem, 4vw, 3rem);
    display: grid;
    grid-template-columns: 1fr 260px;
    gap: clamp(2.5rem, 5vw, 5rem);
    align-items: start;
  }

  @media (max-width: 900px) {
    .page-wrap { grid-template-columns: 1fr; }
    .sidebar   { order: -1; border-bottom: 1px solid var(--border); padding-bottom: 2rem; }
  }

  /* ─── ARTICLE BODY ─── */
  .article-body {
    padding: clamp(3rem, 5vw, 5rem) 0 5rem;
  }

  /* drop cap */
  .article-body > p:first-of-type::first-letter {
    font-family: var(--serif);
    font-size: 5rem;
    font-weight: 700;
    line-height: 0.75;
    float: left;
    margin: 0.1em 0.1em 0 0;
    color: var(--accent);
  }

  .article-body p {
    font-family: var(--serif);
    font-size: clamp(1.05rem, 1.5vw, 1.22rem);
    line-height: 1.95;
    color: var(--text);
    margin-bottom: 1.8em;
    font-weight: 400;
  }

  .article-body h2 {
    font-family: var(--serif);
    font-size: clamp(1.5rem, 2.5vw, 2.2rem);
    font-weight: 500;
    color: var(--white);
    margin: 3.5em 0 1em;
    line-height: 1.2;
    padding-left: 1.2rem;
    border-left: 2px solid var(--accent);
    scroll-margin-top: calc(var(--nav-h) + 3rem);
  }

  .article-body h3 {
    font-family: var(--serif);
    font-size: clamp(1.15rem, 1.8vw, 1.55rem);
    font-weight: 400;
    font-style: italic;
    color: var(--accent);
    margin: 2.5em 0 0.7em;
    line-height: 1.3;
    scroll-margin-top: calc(var(--nav-h) + 3rem);
  }

  .article-body blockquote {
    position: relative;
    margin: 3rem 0;
    padding: 1.75rem 2rem 1.75rem 2.25rem;
    background: var(--surface);
    border-radius: var(--r);
    overflow: hidden;
  }

  .article-body blockquote::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, var(--accent), var(--gold));
  }

  .article-body blockquote::after {
    content: '\201C';
    position: absolute;
    right: 1.5rem; top: 0.5rem;
    font-family: var(--serif);
    font-size: 6rem;
    color: var(--accent);
    opacity: 0.08;
    line-height: 1;
  }

  .article-body blockquote p {
    font-family: var(--serif);
    font-size: clamp(1.1rem, 1.7vw, 1.35rem);
    font-style: italic;
    line-height: 1.75;
    color: var(--white);
    margin: 0;
  }

  .article-body blockquote p::first-letter { all: revert; }

  .article-body a {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-color: rgba(93,206,160,0.35);
    text-underline-offset: 4px;
    transition: text-decoration-color 0.2s;
  }
  .article-body a:hover { text-decoration-color: var(--accent); }

  .article-body ul, .article-body ol {
    padding-left: 1.6rem;
    margin-bottom: 1.75em;
  }

  .article-body li {
    font-family: var(--serif);
    font-size: clamp(1.05rem, 1.5vw, 1.15rem);
    line-height: 1.8;
    color: var(--text);
    margin-bottom: 0.5em;
  }

  .article-body li::marker { color: var(--accent); }

  .article-body img {
    width: 100%;
    height: auto;
    border-radius: var(--r);
    margin: 2.5rem 0;
    border: 1px solid var(--border);
    display: block;
  }

  .article-body hr {
    border: none;
    margin: 3.5rem 0;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--border-2), transparent);
    position: relative;
  }

  .article-body hr::after {
    content: '◆';
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    font-size: 0.55rem;
    color: var(--text-3);
    background: var(--bg);
    padding: 0 1rem;
  }

  .article-body strong { color: var(--white); font-weight: 500; }
  .article-body em     { color: var(--accent); font-style: italic; }

  /* ─── FADE-IN ON SCROLL ─── */
  .article-body .reveal {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .article-body .reveal.visible {
    opacity: 1;
    transform: none;
  }

  /* ─── TAGS ─── */
  .tags-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    padding-top: 2.5rem;
    margin-top: 3rem;
    border-top: 1px solid var(--border);
  }

  .tag {
    font-family: var(--mono);
    font-size: 0.56rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    background: var(--accent-dim);
    border: 1px solid rgba(93,206,160,0.18);
    padding: 0.28rem 0.75rem;
    border-radius: 100px;
    text-decoration: none;
    transition: background 0.15s, border-color 0.15s;
  }
  .tag:hover {
    background: rgba(93,206,160,0.2);
    border-color: rgba(93,206,160,0.35);
  }

  /* ─── SIDEBAR ─── */
  .sidebar {
    padding: clamp(2rem, 4vw, 4rem) 0;
    position: sticky;
    top: calc(var(--nav-h) + 1.5rem);
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .s-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r);
    padding: 1.25rem 1.4rem;
    position: relative;
    overflow: hidden;
  }

  .s-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1.5px;
    background: linear-gradient(90deg, var(--accent), var(--gold));
  }

  .s-heading {
    font-family: var(--mono);
    font-size: 0.55rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--text-3);
    margin-bottom: 1rem;
    padding-bottom: 0.65rem;
    border-bottom: 1px solid var(--border);
  }

  /* TOC */
  #toc-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .toc-item a {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    padding: 0.45rem 0;
    font-family: var(--sans);
    font-size: 0.82rem;
    line-height: 1.4;
    color: var(--text-2);
    text-decoration: none;
    border-bottom: 1px solid var(--border);
    transition: color 0.15s, padding-left 0.15s;
  }

  .toc-item:last-child a { border-bottom: none; }

  .toc-item a::before {
    content: '';
    display: block;
    width: 4px; height: 4px;
    border-radius: 50%;
    background: var(--text-3);
    flex-shrink: 0;
    margin-top: 0.42em;
    transition: background 0.15s;
  }

  .toc-item a:hover {
    color: var(--accent);
    padding-left: 0.35rem;
  }
  .toc-item a:hover::before { background: var(--accent); }
  .toc-item.active a { color: var(--accent); }
  .toc-item.active a::before { background: var(--accent); }

  /* h3 indent */
  .toc-item.depth-3 a {
    padding-left: 1rem;
    font-size: 0.78rem;
    color: var(--text-3);
  }
  .toc-item.depth-3 a::before { width: 3px; height: 3px; }

  #toc-empty {
    font-family: var(--serif);
    font-style: italic;
    font-size: 0.88rem;
    color: var(--text-3);
  }

  /* CTA */
  .cta-card {
    background: linear-gradient(135deg, var(--surface) 0%, var(--surface-2) 100%);
    border: 1px solid var(--border-2);
    border-radius: var(--r);
    padding: 1.5rem;
    position: relative;
    overflow: hidden;
  }

  .cta-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1.5px;
    background: linear-gradient(90deg, var(--accent), var(--gold));
  }

  .cta-card::after {
    content: '';
    position: absolute;
    bottom: -40px; right: -40px;
    width: 120px; height: 120px;
    border-radius: 50%;
    background: var(--accent-glow);
  }

  .cta-card h3 {
    font-family: var(--serif);
    font-size: 1.2rem;
    font-weight: 500;
    line-height: 1.3;
    color: var(--white);
    margin-bottom: 0.6rem;
    position: relative;
    z-index: 1;
  }

  .cta-card p {
    font-size: 0.83rem;
    line-height: 1.65;
    color: var(--text-2);
    margin-bottom: 1.25rem;
    position: relative;
    z-index: 1;
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    background: var(--accent);
    color: var(--bg);
    font-family: var(--mono);
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 500;
    padding: 0.65rem 1.25rem;
    border-radius: var(--r);
    text-decoration: none;
    transition: background 0.2s, transform 0.15s;
    position: relative;
    z-index: 1;
  }

  .cta-btn:hover {
    background: #4ab88a;
    transform: translateY(-1px);
  }

  .cta-btn svg { width: 12px; height: 12px; flex-shrink: 0; }

  /* related */
  .related-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.65rem 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    transition: all 0.15s;
  }
  .related-item:last-child { border-bottom: none; }
  .related-item:hover { padding-left: 0.4rem; }

  .related-item .ri-icon {
    flex-shrink: 0;
    width: 28px; height: 28px;
    border-radius: 4px;
    background: var(--accent-dim);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    margin-top: 0.15rem;
  }

  .related-item .ri-text small {
    display: block;
    font-family: var(--mono);
    font-size: 0.52rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-3);
    margin-bottom: 0.18rem;
  }

  .related-item .ri-text span {
    font-family: var(--serif);
    font-size: 0.9rem;
    line-height: 1.4;
    color: var(--text);
    transition: color 0.15s;
  }

  .related-item:hover .ri-text span { color: var(--accent); }

  /* location chip */
  .location-chip {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 0.75rem;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: var(--r);
  }

  .location-chip svg { color: var(--accent); flex-shrink: 0; }

  .location-chip p {
    font-family: var(--serif);
    font-size: 0.9rem;
    font-style: italic;
    line-height: 1.5;
    color: var(--text-2);
  }

  /* ─── FOOTER ─── */
  .site-footer {
    margin-top: 5rem;
    border-top: 1px solid var(--border);
    padding: 2rem clamp(1.5rem, 4vw, 3rem);
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
    background: var(--bg-2);
  }

  .footer-brand {
    font-family: var(--mono);
    font-size: 0.58rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-3);
  }

  .footer-back {
    font-family: var(--mono);
    font-size: 0.58rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-3);
    text-decoration: none;
    transition: color 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .footer-back:hover { color: var(--accent); }

  /* ─── KEYFRAMES ─── */
  @keyframes up {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 500px) {
    .share-label { display: none; }
    #progress-pct { display: none; }
    .sidebar { position: static; }
  }
  </style>
</head>

<body>

  <!-- READING PROGRESS -->
  <div id="progress-track">
    <div id="progress-fill"></div>
  </div>
  <div id="progress-pct">0%</div>

  <!-- NAV — fixed, overlaid on hero -->
  <NavBar />

  <!-- ══════════════════ HERO ══════════════════ -->
  <header
    class="hero"
    style={image ? `background-image:url('${image}')` : ''}
    aria-label={`Imagen de portada: ${title}`}
  >
    <div class="hero-overlay" aria-hidden="true"></div>

    <div class="hero-content">
      <p class="hero-eyebrow">
        {category} · {siteName}
      </p>

      <h1 class="hero-title">{title}</h1>

      <div class="hero-meta">
        {pubDate && <time datetime={pubDate}>{formattedDate}</time>}
        {pubDate && readingTime && <span class="dot" aria-hidden="true"></span>}
        {readingTime && <span id="reading-time">{readingTime} min de lectura</span>}
      </div>

      {description && <p class="hero-desc">{description}</p>}
    </div>

